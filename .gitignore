# local backups, never part of the package
.backups/
*.bak

# swarm runtime state lives in each project's .swarm/, not here — but ignore any
# that ends up in the repo dir just in case
.swarm/

__pycache__/
*.pyc

# yoke workspaces: created next to harness/yoke at runtime (and by its own
# test suite), never part of the package
harness/ws-*/
