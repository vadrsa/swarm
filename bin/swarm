#!/usr/bin/env python3
# swarm (SIMPLEST) — the whole tool in one file: CLI verbs + hook entrypoints.
#
# Nine concepts, four verbs (+ `world`, which prints the contract). An agent is
# a Claude session in a herdr pane, with a name, a parent, and a journal. A
# message is a claim on one turn. Everything stored on disk is a fact the
# filesystem can witness — who, to whom, when, what, and whether it has yet
# consumed its turn. Nothing here stores a claim about attention, compliance,
# or intent; *obeyed* is judged by the sender reading the recipient's reply,
# pane, journal, or artifact.
#
# Layout under .swarm/ (one swarm per project; override root with SWARM_DIR):
#   queue/<name>/*.json        waiting messages (one file = one undelivered claim)
#   queue/<name>/delivered/    world-readable record: this message consumed a turn
#   journal/<name>.md          the agent's own words; ALSO the name's tombstone
#   agents/<name>.json         the durable name -> pane/parent binding
#   event/<name>.json          the last hook event, as fact (feeds `ps`); no history
#   settings/<name>.*          spawn plumbing (claude settings, task, launcher, status)
#
# Hook entrypoints (argv-dispatched; wired per agent via `claude --settings`):
#   deliver   UserPromptSubmit — inject exactly ONE queued message, oldest first
#   event     Stop/Notification — overwrite the event fact; on Stop, re-ring
#   restore   SessionStart — re-inject the original task + the journal tail

import json
import os
import shlex
import subprocess
import sys
import time

TURN_CAP = 8000          # the ONE size number: a message fits one turn's injection
JOURNAL_TAIL_CAP = 4000  # restore: at most this many chars of journal tail
LAST_WORDS_CAP = 500     # event fact: stored prefix of the last assistant words
NAME_RE = r"^[a-z0-9][a-z0-9-]{0,39}\Z"  # \Z, not $: $ admits a trailing newline

# ---------------------------------------------------------------- primitives

def now_ms():
    return int(time.time() * 1000)


def die(msg):
    print(f"swarm: {msg}", file=sys.stderr)
    sys.exit(1)


def root_dir():
    return os.environ.get("SWARM_DIR") or os.path.join(os.getcwd(), ".swarm")


def my_name():
    return os.environ.get("SWARM_AGENT_ID") or "operator"


def q_dir(root, name):
    return os.path.join(root, "queue", name)


def delivered_dir(root, name):
    return os.path.join(q_dir(root, name), "delivered")


def journal_path(root, name):
    return os.path.join(root, "journal", f"{name}.md")


def agent_rec_path(root, name):
    return os.path.join(root, "agents", f"{name}.json")


def event_path(root, name):
    return os.path.join(root, "event", f"{name}.json")


def settings_dir(root):
    return os.path.join(root, "settings")


def write_atomic(path, text):
    # Inherited mechanism: tmp + rename. A concurrent reader never sees a
    # half-written file; the rename IS the state change.
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = f"{path}.tmp.{os.getpid()}"
    with open(tmp, "w") as f:
        f.write(text)
    os.replace(tmp, path)


def read_json(path):
    try:
        with open(path) as f:
            return json.load(f)
    except Exception:
        return None


def read_stdin_json():
    if sys.stdin.isatty():
        return None
    try:
        raw = sys.stdin.read()
        return json.loads(raw) if raw else None
    except Exception:
        return None


def load_agents(root):
    d = os.path.join(root, "agents")
    out = {}
    if os.path.isdir(d):
        for fn in sorted(os.listdir(d)):
            if not fn.endswith(".json"):
                continue
            r = read_json(os.path.join(d, fn))
            if r and r.get("name"):
                out[r["name"]] = r
    return out


def parents_of(agents):
    return {n: (a.get("parent") or "operator") for n, a in agents.items()}


def fmt_ts(ms):
    try:
        return time.strftime("%Y-%m-%d %H:%M:%SZ", time.gmtime(int(ms) / 1000))
    except Exception:
        return "?"


def fmt_age(ms):
    s = max(0, int(ms / 1000))
    if s < 60:
        return f"{s}s"
    if s < 3600:
        return f"{s // 60}m"
    if s < 86400:
        return f"{s // 3600}h"
    return f"{s // 86400}d"


# ---------------------------------------------------------- message delivery
# A message is a claim on one turn. These functions are the whole of delivery;
# they are pure file logic so tests can exercise them without a pane.

def relation(sender, recipient, parent_of):
    """The sender's relation to the recipient, from the recipient's seat.

    Structural sender class (design §3.4b): the header names who is speaking
    and where they stand, so a directive can never arrive framed as chatter.
    parent_of maps agent name -> parent name ('operator' at the roots).
    """
    if sender == "operator":
        return "the OPERATOR (the human at the root)"
    if parent_of.get(recipient) == sender:
        return "your parent"
    if parent_of.get(sender) == recipient:
        return "your child"
    sp = parent_of.get(sender)
    if sp and sp == parent_of.get(recipient):
        return "your sibling"
    return "another agent"


def list_waiting(root, name):
    """All waiting messages for `name`, oldest first: [(ts, fn, rec)]."""
    d = q_dir(root, name)
    out = []
    if os.path.isdir(d):
        for fn in sorted(os.listdir(d)):
            if not fn.endswith(".json"):
                continue
            p = os.path.join(d, fn)
            if not os.path.isfile(p):
                continue  # skips delivered/ and anything else odd
            r = read_json(p)
            if r and isinstance(r.get("body"), str):
                out.append((int(r.get("ts") or 0), fn, r))
    out.sort(key=lambda c: (c[0], c[1]))
    return out


def select_next(root, name):
    """The ONE message this turn: the oldest. Returns (fn, rec, n_more) or None."""
    waiting = list_waiting(root, name)
    if not waiting:
        return None
    _, fn, rec = waiting[0]
    return fn, rec, len(waiting) - 1


def count_junk(root, name):
    """Queue files that LOOK like messages but do not parse as one. Counted so
    `ps` can show them (ruling R4): an honest unknown beats an invisible file.
    Unreachable via send (atomic JSON writes); a crashed writer could strand one."""
    d = q_dir(root, name)
    n = 0
    if os.path.isdir(d):
        for fn in os.listdir(d):
            p = os.path.join(d, fn)
            if not fn.endswith(".json") or not os.path.isfile(p):
                continue
            r = read_json(p)
            if not (r and isinstance(r.get("body"), str)):
                n += 1
    return n


def delivery_head(rec, rel):
    return (f"[swarm message] from {rec.get('from', '?')} — {rel} — "
            f"sent {fmt_ts(rec.get('ts'))}\n\n")


def build_delivery(fn, rec, rel, to):
    """The exact text injected into the recipient's turn: whole, sender-headed.

    The injection is head + body, nothing else: no queue-depth trailer (ruling
    R1 — `ps` shows q=, and the stop re-ring makes a backlog self-draining),
    so an accepted message is delivered whole unconditionally.

    Returns None when not even a truncation marker fits (a hand-crafted file;
    send refuses anything that cannot fit whole): the caller must deliver
    NOTHING and leave the file queued — never delivered ≠ dropped, and a bare
    header claiming delivery would be the lie WORLD.md forbids (ruling R2).
    """
    head = delivery_head(rec, rel)
    text = head + rec.get("body", "")
    if len(text) > TURN_CAP:
        note = f"\n[truncated — full body on disk: queue/{to}/delivered/{fn}]"
        room = TURN_CAP - len(head) - len(note)
        if room <= 0:
            return None
        text = head + rec.get("body", "")[:room] + note
    return text


def send_size_error(rec, rel):
    """Refusal reason if this message cannot fit one turn's injection, else None.

    Delivery injects exactly head + body, so this check IS the delivery size:
    an accepted message is delivered whole at any queue depth. One number, no
    arithmetic for senders to learn: it fits or you send a file path.
    """
    n = len(delivery_head(rec, rel)) + len(rec.get("body", ""))
    if n > TURN_CAP:
        return (f"message too big: delivering it would take {n} chars against "
                f"the {TURN_CAP}-char turn cap — put it in a file, send the path")
    return None


def queue_put(root, rec):
    """Create rec's queue file without ever overwriting one. Two sends from
    one sender to one recipient in the same millisecond collide on
    {ts}-{from}.json, and tmp+rename would silently replace the first — the
    drop WORLD.md forbids. So claim the name with O_CREAT|O_EXCL and on
    collision bump ts by 1 and retry (bounded): the second message lands a
    millisecond later instead of vanishing. The exclusive create replaces
    tmp+rename here; a reader that catches the file mid-write skips it as
    unparseable and finds it whole next pass — delayed, never lost. Returns
    the filename; raises FileExistsError if the bump space is exhausted."""
    d = q_dir(root, rec["to"])
    os.makedirs(d, exist_ok=True)
    for _ in range(1000):
        fn = f"{rec['ts']}-{rec['from']}.json"
        try:
            fd = os.open(os.path.join(d, fn),
                         os.O_CREAT | os.O_EXCL | os.O_WRONLY)
        except FileExistsError:
            rec["ts"] += 1
            continue
        with os.fdopen(fd, "w") as f:
            f.write(json.dumps(rec))
        return fn
    raise FileExistsError(f"queue name space exhausted near {fn}")


def emit_hook_output(obj):
    """Write hook JSON to stdout and WAIT for it to drain. True = delivered.

    The G17 discipline, inherited: side effects are conditional on the bytes
    actually leaving. Python's write()/flush() block until the pipe took the
    bytes or raise — unlike node, which discarded its queued stdout at exit
    and silently destroyed every payload over the ~64 KiB pipe buffer.
    """
    try:
        sys.stdout.write(json.dumps(obj))
        sys.stdout.flush()
        return True
    except OSError:
        # Point fd 1 at /dev/null so the interpreter's own exit-flush of the
        # broken pipe cannot fail after our exit(0) — without this, python
        # dies with status 120 and the "any error -> exit 0" promise is false
        # (ruling R3). The undelivered bytes are already accounted for: the
        # caller keeps the message queued.
        try:
            os.dup2(os.open(os.devnull, os.O_WRONLY), sys.stdout.fileno())
        except OSError:
            pass
        return False


def next_delivery(root, name, parent_of):
    """The queue head as it would be delivered: (fn, ctx). ctx is None for an
    undeliverable head (ruling R2), the whole result is None on an empty queue.
    The ONE definition of deliverability — deliver_once injects with it and the
    stop re-ring rings by it, so they cannot disagree (ruling R7)."""
    sel = select_next(root, name)
    if not sel:
        return None
    fn, rec, _ = sel
    return fn, build_delivery(fn, rec,
                              relation(rec.get("from", "?"), name, parent_of),
                              name)


def deliver_once(root, name, parent_of, emit):
    """Deliver at most ONE message: emit it, and move it to delivered/ ONLY
    after the emit reports the bytes drained. On a failed emit the file stays
    put and is offered whole again next turn — the safe direction to fail."""
    nd = next_delivery(root, name, parent_of)
    if not nd:
        return False
    fn, ctx = nd
    if ctx is None:
        # Undeliverable (ruling R2): emit nothing, move nothing. The file
        # stays visible in `ps` q= — and it blocks the queue behind it, which
        # is deliberate: silently skipping it would hide a file that only a
        # hand-crafted write can produce.
        return False
    ok = emit({"hookSpecificOutput": {"hookEventName": "UserPromptSubmit",
                                      "additionalContext": ctx}})
    if ok:
        try:
            os.makedirs(delivered_dir(root, name), exist_ok=True)
            os.replace(os.path.join(q_dir(root, name), fn),
                       os.path.join(delivered_dir(root, name), fn))
        except OSError:
            pass  # worst case: re-delivered next turn; never lost
    return ok


# ----------------------------------------------------------- restore payload

def journal_tail(path, cap=JOURNAL_TAIL_CAP):
    """The journal's last `cap` chars; a truncation marker points at the rest."""
    try:
        with open(path) as f:
            text = f.read()
    except OSError:
        return ""
    if len(text) <= cap:
        return text
    return (f"[…journal truncated to its last {cap} chars — "
            f"read the full file: {path}]\n") + text[-cap:]


def build_restore(task_text, jpath, source):
    """SessionStart injection: the original task + the journal tail."""
    resumed = ("AFTER A CONTEXT COMPACTION — your working memory was just "
               "summarized away; your journal is your most reliable record"
               if source == "compact" else "a fresh session")
    tail = journal_tail(jpath)
    return (f"[swarm restore] You are resuming {resumed}.\n\n"
            f"--- YOUR ORIGINAL TASK ---\n{task_text}\n\n"
            f"--- YOUR JOURNAL (tail) ---\n{tail or '(journal is empty)'}\n\n"
            f"Continue from where the journal leaves off, and keep appending "
            f"to it as you work.")


# --------------------------------------------------------------- event facts

def last_assistant_text(transcript_path):
    """The last assistant words from the transcript, whitespace-collapsed."""
    try:
        if not transcript_path or not os.path.exists(transcript_path):
            return ""
        with open(transcript_path) as f:
            lines = [l for l in f.read().split("\n") if l]
        for line in reversed(lines):
            try:
                o = json.loads(line)
            except Exception:
                continue
            msg = o.get("message")
            if not msg or msg.get("role") != "assistant":
                continue
            c = msg.get("content")
            if isinstance(c, str):
                text = c
            elif isinstance(c, list):
                text = " ".join(b.get("text", "") for b in c
                                if isinstance(b, dict) and b.get("type") == "text")
            else:
                text = ""
            text = " ".join(text.split())
            if text:
                return text
        return ""
    except Exception:
        return ""


def record_event(root, name, kind, last_words, ts):
    """Overwrite the ONE per-agent event fact: event name, ts, last words.
    No history, no done/question/blocked taxonomy, no heuristics — `ps` shows
    the fact and the pane is one command away."""
    write_atomic(event_path(root, name), json.dumps(
        {"event": kind, "ts": ts, "last_words": (last_words or "")[:LAST_WORDS_CAP]}))


# ------------------------------------------------------------------ ps view

def render_ps(agents, live, queues, events, me_name, op_mail, now, junk=None):
    """The one view. Pure: every input is a plain value, so it tests offline.

    agents:  {name: record}         live:  set of live pane ids, or None (herdr unknown)
    queues:  {name: waiting-count}  events:{name: event fact or None}
    op_mail: [(from, ts)] waiting operator messages, oldest first
    junk:    {name: unparseable-queue-file count} (ruling R4; may be None)

    Dead agents render compactly — names only, one shared line (ruling R5):
    the living tree stays one screen however long the swarm's history grows.
    A live agent under a dead parent reattaches to its nearest living ancestor
    so hiding the dead never orphans the living.
    """
    junk = junk or {}
    lines = []
    if op_mail:
        lines.append(f"operator — {len(op_mail)} message(s) waiting for the human "
                     f"(queue/operator/):")
        for frm, ts in op_mail:
            lines.append(f"    from {frm}, {fmt_age(now - ts)} ago")
    else:
        lines.append("operator — no waiting mail")

    def is_dead(a):
        return live is not None and a.get("pane") not in live
    dead = sorted(n for n, a in agents.items() if is_dead(a))
    shown_set = {n for n in agents if n not in dead}

    def eff_parent(n):
        # nearest non-dead ancestor; a chain that leaves the records keeps its
        # last (unknown) name so the orphan line below can report it
        p = agents[n].get("parent") or "operator"
        seen = set()
        while p in agents and p not in shown_set and p not in seen:
            seen.add(p)
            p = agents[p].get("parent") or "operator"
        return p

    kids = {}
    for n in shown_set:
        kids.setdefault(eff_parent(n), []).append(n)
    for k in kids:
        kids[k].sort()

    def q_of(n):
        return f"q={queues.get(n, 0)}" + (f"+{junk[n]}?" if junk.get(n) else "")

    def walk(name, prefix, is_last):
        a = agents[name]
        branch = "└─ " if is_last else "├─ "
        you = " (you)" if name == me_name else ""
        ev = events.get(name)
        idle = f"idle {fmt_age(now - ev['ts'])}" if ev and ev.get("ts") else "idle ?"
        alive = "live" if live is not None else "?"
        lines.append(f"{prefix}{branch}{name}{you} [{alive}] {q_of(name)} {idle}")
        if ev and ev.get("last_words"):
            cont = "   " if is_last else "│  "
            lines.append(f'{prefix}{cont}   last: "{ev["last_words"][:80]}"')
        ch = kids.get(name, [])
        for i, c in enumerate(ch):
            walk(c, prefix + ("   " if is_last else "│  "), i == len(ch) - 1)

    roots = kids.get("operator", [])
    if not agents:
        lines.append("(no agents)")
    for i, r in enumerate(roots):
        walk(r, "", i == len(roots) - 1)
    # A live agent whose parent chain ends at an unknown name still renders
    # (flat), so nothing alive can be invisible to the one view.
    in_tree = set()

    def collect(n):
        in_tree.add(n)
        for c in kids.get(n, []):
            collect(c)
    for r in roots:
        collect(r)
    for n in sorted(shown_set - in_tree):
        a = agents[n]
        alive = "live" if live is not None else "?"
        lines.append(f"?─ {n} [parent {a.get('parent', '?')} unknown] "
                     f"[{alive}] {q_of(n)}")
    if dead:
        lines.append(f"dead: {', '.join(dead)}")
    return "\n".join(lines)


def subtree(agents, root_name):
    """root_name + every descendant, by walking recorded parent edges."""
    kids = {}
    for n, a in agents.items():
        kids.setdefault(a.get("parent") or "operator", []).append(n)
    out, stack, seen = [], [root_name], set()
    while stack:
        x = stack.pop()
        if x in seen:
            continue
        seen.add(x)
        if x in agents:
            out.append(x)
        stack.extend(kids.get(x, []))
    return out


# ---------------------------------------------------------------- herdr edge
# Everything below talks to a live pane. Exempt from unit tests by the brief;
# kept thin so the logic above stays pure.

def herdr_json(args, timeout=15):
    try:
        p = subprocess.run(["herdr"] + args, capture_output=True, text=True,
                           timeout=timeout)
        return json.loads(p.stdout)
    except Exception:
        return None


def live_pane_set():
    d = herdr_json(["pane", "list"])
    if not d:
        return None  # herdr unreachable: liveness unknown, never asserted
    return {p.get("pane_id") for p in d.get("result", {}).get("panes", [])
            if p.get("pane_id")}


def pane_prompt_line(pane):
    try:
        p = subprocess.run(["herdr", "pane", "read", pane, "--source", "visible",
                            "--lines", "40"], capture_output=True, text=True,
                           timeout=10)
        rows = [l for l in p.stdout.splitlines() if "❯" in l]
        return rows[-1].split("❯", 1)[1].strip() if rows else ""
    except Exception:
        return ""


def ring_doorbell(pane, text="check queue"):
    """Submit a short non-empty prompt to a pane so UserPromptSubmit fires and
    `deliver` runs. send-text arrives via bracketed paste, so wait for the
    prompt box to settle before Enter, then confirm it drained (bounded
    retries). Best-effort by contract: the queue file is already durable, so
    every failure here only delays pickup to the next natural turn."""
    try:
        p = subprocess.run(["herdr", "pane", "send-text", pane, text],
                           capture_output=True, timeout=10)
        if p.returncode != 0:
            return False
    except Exception:
        return False
    prev = None
    for _ in range(20):
        cur = pane_prompt_line(pane)
        if cur and cur == prev:
            break
        prev = cur
        time.sleep(0.2)
    for _ in range(5):
        try:
            p = subprocess.run(["herdr", "pane", "send-keys", pane, "Enter"],
                               capture_output=True, timeout=10)
            if p.returncode != 0:
                return False
        except Exception:
            return False
        time.sleep(0.4)
        if pane_prompt_line(pane) == "":
            return True
        time.sleep(0.3)
    return True  # text + Enter went out; treat as rung (queue is durable anyway)


def ring_doorbell_once(pane, text="check queue"):
    """One-attempt ring for the Stop hook, which blocks its own agent's next
    turn until it returns: one send-text, a short pause for the paste to land,
    one Enter — never a pane read, never a settle loop. Field evidence
    (2026-07-10): the full ring's settle loop spun ~20 x 10s herdr reads
    against a loaded pane, freezing the agent ~3 minutes while deliverable
    mail waited. A ring skipped or missed here is degradation, never loss —
    the queue file is durable and the next natural turn delivers it."""
    try:
        p = subprocess.run(["herdr", "pane", "send-text", pane, text],
                           capture_output=True, timeout=5)
        if p.returncode != 0:
            return False
        time.sleep(0.5)
        p = subprocess.run(["herdr", "pane", "send-keys", pane, "Enter"],
                           capture_output=True, timeout=5)
        return p.returncode == 0
    except Exception:
        return False


# -------------------------------------------------------------- hook verbs

def cmd_deliver():
    # UserPromptSubmit. Bulletproof: any error -> exit 0, no output, turn intact.
    if my_name() == "operator":
        sys.exit(0)
    read_stdin_json()  # drain the payload; delivery needs nothing from it
    try:
        root = root_dir()
        deliver_once(root, my_name(), parents_of(load_agents(root)),
                     emit_hook_output)
    except Exception:
        pass
    sys.exit(0)


def cmd_event(kind):
    # Stop/Notification. Record the fact; on Stop with a non-empty queue,
    # re-ring our own doorbell so the queue keeps draining while we idle.
    if kind not in ("stop", "notification"):
        die(f"event: unknown kind '{kind}' (stop | notification)")
    if my_name() == "operator":
        sys.exit(0)
    payload = read_stdin_json() or {}
    root, name = root_dir(), my_name()
    try:
        record_event(root, name, kind,
                     last_assistant_text(payload.get("transcript_path") or ""),
                     now_ms())
    except Exception:
        pass
    # >>> THE ONE UNPROVEN MECHANISM (design §6.3): the stop re-ring. <<<
    # One-per-turn needs the queue to keep draining after the agent goes idle:
    # on Stop, ring our OWN pane's doorbell — the single-attempt variant, not
    # send's settle-and-confirm ring: this hook blocks the agent's next turn,
    # so it must return fast rather than poll a busy pane. Ring only if the
    # head is DELIVERABLE (ruling R7): ringing for a head that
    # build_delivery refuses would loop forever (ring, empty turn, Stop, still
    # queued, ring...) burning tokens with nobody watching. If the ring proves
    # unreliable, later messages stall until the next natural turn —
    # degradation, never loss: the queue files are durable and `deliver` picks
    # them up whenever the next turn comes.
    if kind == "stop":
        try:
            nd = next_delivery(root, name, parents_of(load_agents(root)))
            if nd and nd[1] is not None:
                rec = read_json(agent_rec_path(root, name))
                if rec and rec.get("pane"):
                    ring_doorbell_once(rec["pane"])
        except Exception:
            pass
    sys.exit(0)


def cmd_restore():
    # SessionStart (startup or post-compaction): original task + journal tail.
    if my_name() == "operator":
        sys.exit(0)
    payload = read_stdin_json() or {}
    root, name = root_dir(), my_name()
    try:
        task = ""
        try:
            with open(os.path.join(settings_dir(root), f"{name}.task")) as f:
                task = f.read()
        except OSError:
            pass
        emit_hook_output({"hookSpecificOutput": {
            "hookEventName": "SessionStart",
            "additionalContext": build_restore(task, journal_path(root, name),
                                               payload.get("source") or "startup")}})
    except Exception:
        pass
    sys.exit(0)


# --------------------------------------------------------------- CLI verbs

def claim_name(root, name):
    """Atomically claim `name` by creating its journal — the tombstone. The
    journal file existing IS 'this name was used'; no ledger, no suffixing.
    Raises FileExistsError on a name ever used."""
    jpath = journal_path(root, name)
    os.makedirs(os.path.dirname(jpath), exist_ok=True)
    fd = os.open(jpath, os.O_CREAT | os.O_EXCL | os.O_WRONLY)
    return fd


def spawn_header(name, parent):
    parent_desc = ("the human operator" if parent == "operator"
                   else f"agent `{parent}`")
    return (
        f"You are agent {name} in a swarm — a tree of Claude agents. Your parent, "
        f"who judges and approves your work: {parent_desc}.\n"
        f"You have the `swarm` CLI: `swarm spawn <name> \"<task>\"` to delegate, "
        f"`swarm send <name>` to message (a message is a claim on one turn), "
        f"`swarm ps` to see the whole tree, `swarm world` for the full contract — "
        f"read it before coordinating others.\n\n"
        f"Your duties (briefed, not enforced): keep your journal at "
        f".swarm/journal/{name}.md — append timestamped entries in your own words "
        f"as you work, and always before going idle; a reconciliation entry names "
        f"its falsifier (the observation that would show you are off track). "
        f"Report to your parent when done or stuck. Produce concrete, inspectable "
        f"artifacts — all work, including yours, is judged by reading it, never "
        f"by claims.\n\n"
        f"Delegate by default: keep judgment, verification, and glue; spawn "
        f"children for the work itself — doing parallelizable work serially "
        f"yourself is off-track. Each reconciliation, ask whether the tree still "
        f"matches the remaining work and whether your span still matches your "
        f"attention: spawn what is missing, close harvested children whose "
        f"workstream is done, split what you cannot attend, absorb what no "
        f"longer earns its layer — keep a child only if you can name its next "
        f"task. "
        f"You are over span when you can no longer name each child's state and "
        f"the next artifact you expect from it without re-reading. If a spawn "
        f"would take you past that, spawn a coordinator and split the stream "
        f"instead; when a coordinator's stream shrinks to what you can hold "
        f"directly, absorb it — harvest, close, take the survivors. The "
        f"operator's span is theirs to declare and yours to protect: never let "
        f"the tree press more direct attention on the operator than they asked "
        f"for. "
        f"When you judge a child's work, judge its delegation too. Closing a "
        f"subtree to re-form a better shape is normal and encouraged — harvest "
        f"its journal and artifacts first, journal the reason; files survive "
        f"close, and burned names are the record working as designed.\n\n"
        f"--- YOUR TASK ---\n")


def write_launcher(launcher, statusfile, settings, taskfile, model):
    # Inherited mechanism (G14): the task lives in a FILE; herdr only ever sees
    # the launcher's path — zero escaping, zero multibyte on argv. The launcher
    # pre-flights and records its outcome to the status file, so spawn can tell
    # a started harness from a dead one by a fired signal, not a screen scrape.
    lines = [
        "#!/usr/bin/env bash",
        "set -uo pipefail",
        f"STATUS={shlex.quote(statusfile)}",
        "if ! command -v claude >/dev/null 2>&1; then",
        '  echo "failed: claude not found on PATH" > "$STATUS"',
        '  echo "[swarm] ERROR: claude not found on PATH in this pane" >&2',
        "  exec bash",
        "fi",
        f"if [ ! -r {shlex.quote(settings)} ]; then",
        f'  echo "failed: settings unreadable: {settings}" > "$STATUS"',
        "  exec bash",
        "fi",
        f'PROMPT="$(cat {shlex.quote(taskfile)})"',
        'echo "launching" > "$STATUS"',
        (f'claude --settings {shlex.quote(settings)} --model {shlex.quote(model)} "$PROMPT"'
         if model else f'claude --settings {shlex.quote(settings)} "$PROMPT"'),
        "rc=$?",
        'if [ "$rc" -ne 0 ]; then echo "failed: claude exited code $rc" > "$STATUS"; fi',
        "exec bash",  # keep the pane inspectable after claude ends
    ]
    with open(launcher, "w") as f:
        f.write("\n".join(lines) + "\n")
    os.chmod(launcher, 0o755)


def cmd_spawn(argv):
    if len(argv) < 2:
        die('spawn needs: swarm spawn <name> "<task>" [--model M] [--cwd DIR]')
    name, task = argv[0], argv[1]
    rest, model, cwd = argv[2:], "", os.getcwd()
    while rest:
        if rest[0] == "--model" and len(rest) > 1:
            model, rest = rest[1], rest[2:]
        elif rest[0] == "--cwd" and len(rest) > 1:
            cwd, rest = rest[1], rest[2:]
        else:
            die(f"spawn: unknown flag {rest[0]}")
    import re as _re
    if not _re.match(NAME_RE, name):
        die(f"bad name '{name}': lowercase letters, digits, hyphens (max 40). "
            f"The name is chosen, not derived — pick one that names the work.")
    if name in ("operator", "delivered"):
        die(f"'{name}' is reserved")
    if not task.strip():
        die("spawn needs a non-empty task")
    if os.environ.get("HERDR_ENV") != "1":
        die("not inside herdr (HERDR_ENV != 1); spawn needs herdr as the container")

    root = root_dir()
    parent = my_name()

    # Claim the name FIRST: journal-as-tombstone. A name ever used errors here.
    try:
        fd = claim_name(root, name)
    except FileExistsError:
        die(f"name '{name}' was already used (journal/{name}.md exists); "
            f"a name is one agent, forever — pick another")
    with os.fdopen(fd, "w") as f:
        f.write(f"# journal of {name}\n\n## {fmt_ts(now_ms())} — spawned\n"
                f"Task from {parent}: {task}\n")

    # Spawn plumbing: settings (hooks -> this file), task file, launcher.
    sdir = settings_dir(root)
    os.makedirs(sdir, exist_ok=True)
    self_path = shlex.quote(os.path.realpath(__file__))

    def h(cmd):
        return {"matcher": "", "hooks": [{"type": "command",
                                          "command": f"{self_path} {cmd}"}]}
    settings = os.path.join(sdir, f"{name}.json")
    write_atomic(settings, json.dumps({"hooks": {
        "UserPromptSubmit": [h("deliver")],
        "Stop": [h("event stop")],
        "Notification": [h("event notification")],
        "SessionStart": [h("restore")]}}))
    taskfile = os.path.join(sdir, f"{name}.task")
    write_atomic(taskfile, spawn_header(name, parent) + task)
    statusfile = os.path.join(sdir, f"{name}.status")
    try:
        os.unlink(statusfile)
    except OSError:
        pass
    launcher = os.path.join(sdir, f"{name}.launch.sh")
    write_launcher(launcher, statusfile, settings, taskfile, model)

    # One tab per agent: the pane is what makes the society observable.
    d = herdr_json(["tab", "create", "--cwd", cwd, "--no-focus", "--label", name,
                    "--env", f"SWARM_DIR={root}", "--env", f"SWARM_AGENT_ID={name}"])
    pane = tab = ""
    try:
        pane = d["result"]["root_pane"]["pane_id"]
        tab = d["result"]["tab"]["tab_id"]
    except Exception:
        pass
    if not pane:
        die("herdr tab create failed")
    subprocess.run(["herdr", "pane", "run", pane, launcher], capture_output=True)

    # Record the binding BEFORE the readiness wait: the record + the launcher
    # signal are the truth; a slow start must never lose the agent.
    write_atomic(agent_rec_path(root, name), json.dumps(
        {"name": name, "parent": parent, "pane": pane, "tab": tab,
         "model": model, "cwd": cwd, "task": task, "ts": now_ms()}))

    # Readiness = the launcher's own fired signal. Ambiguity is life: only a
    # CONFIRMED "failed" tears down; a silent timeout keeps the agent.
    timeout = int(os.environ.get("SWARM_READY_TIMEOUT", "30"))
    t0, outcome = time.time(), "unknown"
    while True:
        try:
            with open(statusfile) as f:
                s = f.read()
            if s.startswith("failed"):
                outcome = "failed"
                break
            if s.startswith("launching"):
                outcome = "started"
                break
        except OSError:
            pass
        if time.time() - t0 >= timeout:
            break
        time.sleep(1)
    if outcome == "failed":
        with open(statusfile) as f:
            reason = f.read().strip()
        if tab:
            subprocess.run(["herdr", "tab", "close", tab], capture_output=True)
        try:
            os.unlink(agent_rec_path(root, name))  # binding goes; tombstone stays
        except OSError:
            pass
        die(f"agent {name} did not start: {reason}")
    if outcome == "unknown":
        print(f"swarm: warning: {name} launch unconfirmed after {timeout}s; "
              f"keeping it — check its pane", file=sys.stderr)
    print(name)


def cmd_send(argv):
    to, body, from_stdin, have_pos = "", "", False, False
    rest = list(argv)
    while rest:
        a = rest.pop(0)
        if a == "--stdin":
            from_stdin = True
        elif a.startswith("-"):
            die(f"send: unknown flag {a}")
        elif not to:
            to = a
        else:
            body, have_pos = a, True
    if from_stdin:
        # Bytes off stdin, never a shell word: a positional body containing
        # backticks/$()/apostrophes is mangled by the CALLER's shell before we
        # can see it. Passing both is an error, not a precedence rule.
        if have_pos:
            die("send: --stdin takes the body from stdin; drop the positional message")
        if sys.stdin.isatty():
            die("send --stdin: no message on stdin (pipe or redirect one in)")
        body = sys.stdin.read()
    if not to or not body:
        die('send needs: swarm send <name> --stdin   (or: swarm send <name> "<msg>")')

    root = root_dir()
    agents = load_agents(root)
    if to != "operator" and to not in agents:
        die(f"unknown agent: {to}")
    sender = my_name()
    rec = {"to": to, "from": sender, "ts": now_ms(), "body": body}
    err = send_size_error(rec, relation(sender, to, parents_of(agents)))
    if err:
        die(err)
    try:
        queue_put(root, rec)
    except OSError as e:
        die(f"could not queue message: {e}")

    # Doorbell, best-effort. The operator is a mailbox, not a node: no pane,
    # no doorbell, no warning — the human sees the mail at the top of `ps`.
    if to != "operator":
        pane = agents[to].get("pane", "")
        if not (pane and ring_doorbell(pane)):
            print(f"swarm: note: doorbell to {to} skipped (pane unavailable); "
                  f"message is durably queued for {to}'s next turn", file=sys.stderr)


def cmd_ps(argv):
    if argv:
        die("ps takes no arguments")
    root = root_dir()
    agents = load_agents(root)
    live = live_pane_set()
    queues = {n: len(list_waiting(root, n)) for n in agents}
    junk = {n: count_junk(root, n) for n in agents}
    events = {n: read_json(event_path(root, n)) for n in agents}
    op_mail = [(r.get("from", "?"), int(r.get("ts") or 0))
               for _, _, r in list_waiting(root, "operator")]
    out = render_ps(agents, live, queues, events, my_name(), op_mail, now_ms(),
                    junk)
    if live is None and agents:
        out += "\n(herdr unreachable — liveness unknown)"
    print(out)


def cmd_close(argv):
    if len(argv) != 1:
        die("close needs exactly one name: swarm close <name>")
    root = root_dir()
    agents = load_agents(root)
    name = argv[0]
    if name not in agents:
        die(f"unknown agent: {name}")
    for aid in subtree(agents, name):
        a = agents[aid]
        closed = False
        if a.get("tab"):
            p = subprocess.run(["herdr", "tab", "close", a["tab"]],
                               capture_output=True)
            closed = p.returncode == 0
        if not closed and a.get("pane"):
            p = subprocess.run(["herdr", "pane", "close", a["pane"]],
                               capture_output=True)
            closed = p.returncode == 0
        print(f"closed {aid}" if closed else f"{aid}: pane already gone")
    print(f"files stay under {root} (journal, queue, delivered)")


def cmd_world():
    # WORLD.md sits at the repo root, one level above bin/ (realpath first:
    # the installed `swarm` is a symlink into the checkout)
    doc = os.path.join(
        os.path.dirname(os.path.dirname(os.path.realpath(__file__))), "WORLD.md")
    try:
        with open(doc) as f:
            sys.stdout.write(f.read())
    except OSError:
        die(f"WORLD.md not found at the repo root (expected {doc})")


USAGE = """swarm (simplest) — four verbs. An agent is a session in a pane with a
name, a parent, and a journal. A message is a claim on one turn.

  swarm spawn <name> "<task>" [--model M] [--cwd DIR]   create a child; the name
                                is chosen, not derived; a name ever used errors
  swarm send <name> --stdin     message an agent or `operator` (body from stdin —
  swarm send <name> "<msg>"     recommended; a positional body is a shell word).
                                Delivered whole, ONE per turn, oldest first. Must
                                fit one turn's injection (8000 chars) or send
                                refuses: put it in a file, send the path.
  swarm ps                      the one view: tree, liveness, queue depth,
                                idle-since, last words; operator mail on top
  swarm close <name>            end an agent and its subtree; files stay
  swarm world                   print the contract (two screens)

State: ./.swarm (override with SWARM_DIR). Journals at .swarm/journal/<name>.md —
world-readable; read your children's. deliver/event/restore are hook entrypoints
(wired automatically at spawn), not for humans."""


def main(argv):
    if not argv or argv[0] in ("-h", "--help", "help"):
        print(USAGE)
        sys.exit(0 if argv else 1)
    verb, rest = argv[0], argv[1:]
    if verb == "spawn":
        cmd_spawn(rest)
    elif verb == "send":
        cmd_send(rest)
    elif verb == "ps":
        cmd_ps(rest)
    elif verb == "close":
        cmd_close(rest)
    elif verb == "world":
        cmd_world()
    elif verb == "deliver":
        cmd_deliver()
    elif verb == "event":
        cmd_event(rest[0] if rest else "")
    elif verb == "restore":
        cmd_restore()
    else:
        print(USAGE, file=sys.stderr)
        die(f"unknown verb: {verb}")


if __name__ == "__main__":
    main(sys.argv[1:])
