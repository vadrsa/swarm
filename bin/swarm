#!/usr/bin/env python3
# swarm (SIMPLEST) — the whole tool in one file: CLI verbs + hook entrypoints.
#
# Nine concepts, four verbs (+ `world`, which prints the contract, and `models`,
# a read-only discovery verb). An agent is
# a Claude session in a herdr pane, with a name, a parent, and a journal. A
# message is a claim on one turn. Everything stored on disk is a fact the
# filesystem can witness — who, to whom, when, what, and whether it has yet
# consumed its turn. Nothing here stores a claim about attention, compliance,
# or intent; *obeyed* is judged by the sender reading the recipient's reply,
# pane, journal, or artifact.
#
# Layout under .swarm/ (one swarm per project; override root with SWARM_DIR):
#   queue/<name>/*.json        waiting messages (one file = one undelivered claim)
#   queue/<name>/delivered/    world-readable record: this message consumed a turn
#   journal/<name>.md          the agent's own words; ALSO the name's tombstone
#   agents/<name>.json         the durable name -> pane/parent binding
#   event/<name>.json          the last hook event, as fact (feeds `ps`); no history
#   settings/<name>.*          spawn plumbing (claude settings, task, launcher, status)
#
# Hook entrypoints (argv-dispatched; wired per agent via `claude --settings`):
#   deliver   UserPromptSubmit — inject exactly ONE queued message, oldest first
#   event     Stop/Notification — overwrite the event fact; on Stop, re-ring
#   restore   SessionStart — re-inject the original task + the journal tail

import concurrent.futures
import json
import os
import shlex
import shutil
import subprocess
import sys
import time

TURN_CAP = 8000          # the ONE size number: a message fits one turn's injection
JOURNAL_TAIL_CAP = 4000  # restore: at most this many chars of journal tail
LAST_WORDS_CAP = 500     # event fact: stored prefix of the last assistant words
MODEL_CAP = 40           # ps view: a pinned model id. Measured, not guessed: the longest id in
                         # the field is 25 ('claude-haiku-4-5-20251001'), but a shipping Bedrock
                         # id is 33 ('us.anthropic.claude-opus-4-8-v1:0'). 40 leaves headroom.
                         # Over the cap renders with an ellipsis — a cut id must never pass for
                         # a whole one.
# Characters a pinned model may never contain, because they do STRUCTURAL work in the ps view:
# the parens that delimit '(you)', and the box-drawing glyphs that draw the tree. Whitespace goes
# too (a newline would forge a row). This is an EXCLUDE list on purpose. A whitelist of the
# "obvious" id alphabet silently mangles real ids — 'claude-opus-4-8[1m]' loses its brackets and
# the Bedrock 'v1:0' becomes 'v10', which is precisely the plausible-but-wrong id this view exists
# not to print. Exclude what breaks the view; never guess at what an id may contain.
MODEL_STRUCTURAL = set("()") | set("─│├└┌┐┘┬┴┼")
REASON_CAP = 500         # the record keeps the reason verbatim; this caps only what a
                         # caller may pass, so one spawn cannot write an unbounded blob
                         # into a file every `ps` and `restore` reads. A clause, not an essay.
NAME_RE = r"^[a-z0-9][a-z0-9-]{0,39}\Z"  # \Z, not $: $ admits a trailing newline

# Models a parent may pin. This is a POLICY list, not a capability list — the two differ,
# and the difference is the honest part. There is no `default` token: a spawn with no
# --model is always an error (spawn_mandate_error()), and no configured default can rescue
# it. Silence is never free — "always force to think" (operator override, CONFIG-NOTES #1,
# 2026-07-15). This tightens the earlier mandate, which let `--model default` stand in for
# an explicit choice; that escape hatch is gone — every accepted model resolves to a
# concrete launcher --model, and config [models] aliases (see read_config) extend this set
# by name, never by inventing a silent fallback.
#
# haiku was banned 2026-07-13 on the claim "it doesn't have auto mode" — a capability claim
# that was never independently measured (docs/audit/weak-model-delegation-2026-07-13.md's own
# conclusion: the wedge is a permission gate swarm hands EVERY child regardless of model, Opus
# would block too, and the settling probe was never run). With every child now getting an
# explicit --permission-mode (this file, 2026-07-14), the probe WAS run: a haiku-pinned child,
# spawned with acceptEdits, cleared the permission wall, edited a real file unattended, and
# reached Stop with real last words (`swarm ps` showed it `[live] idle`, not wedged). The ban
# rested on an unmeasured claim; the measurement says otherwise. Lifted.
SPAWN_MODELS = ("opus", "sonnet", "fable", "haiku")
BANNED_MODELS = ()
# Verbatim from `claude --help` (2026-07-14), the --permission-mode flag's own
# accepted-values list — not guessed, not carried over from the settings-JSON
# schema, which spells the "ask me" state differently ("default" there vs
# "manual" here). This is the vocabulary that actually reaches the `claude`
# argv, so it is the one spawn validates against.
PERMISSION_MODES = ("acceptEdits", "auto", "bypassPermissions", "manual",
                     "dontAsk", "plan")
# The default every spawned child gets unless overridden (--permission-mode or
# .swarm/config's "spawn" key: {"spawn": {"permission_mode": ...}}). Without
# it a child inherits the
# MACHINE's ambient default — which is how the WSL field bug happened: swarm set
# no mode, his machine defaulted to manual, and every child wedged on the first
# dialog, rendering as plain "idle" in `ps`. Invisible.
#
# auto, not acceptEdits. Measured (real claude, empty settings file so no
# ambient default could leak in) — both modes share the same in-cwd blast
# radius; egress is the ENTIRE difference:
#   in-cwd Edit/Write ....... allowed unattended   <- both modes
#   in-cwd Bash, incl. `rm` . ALLOWED UNATTENDED   <- both modes, say it plainly
#   writes OUTSIDE the cwd .. blocked (sandbox)     <- both modes
#   network egress .......... BLOCKED (acceptEdits) vs ALLOWED (auto)
# So a child can already do real damage inside its own working directory under
# EITHER mode. The one thing this default decides is whether it can also fetch
# a doc, call an API, or install a package while unattended — or send data out
# while unattended. Both readings are correct; there is no free lunch here.
#
# Why auto anyway: it is the TRUE status quo, not a widening. This machine's own
# ~/.claude/settings.json says defaultMode "auto" — every child ever spawned
# here already ran with exactly this privilege, inherited by accident from a
# file swarm does not own. swarm's actual contribution was never "narrow the
# machine's default" — it was "SPECIFY a mode instead of silently inheriting
# whatever the machine happens to have," which is what fixed the WSL wedge
# above. That fix holds regardless of which mode is chosen here. Given that,
# picking acceptEdits bought a narrower default than what every agent here was
# already running with, at the cost of blocking the network calls most agents
# actually need (fetching a doc, calling an API, installing a package) — an
# agent that cannot reach the network is unattended right up until the moment
# it needs to be attended, which defeats the point of "unattended."
#
# The cost, stated plainly and not softened: a child running under auto CAN
# send data out over the network without anyone watching. That is a real
# exfiltration surface, not a hypothetical one, and it is the entire price of
# this default. bypassPermissions (== --dangerously-skip-permissions) is a
# different, larger step — it also drops the out-of-cwd write sandbox — and
# stays distinct, opt-in, and deliberately NOT the default.
#
# Known gap, real, pre-existing, and now SHARPER (docs/audit/spawn-red-2026-07-14.md):
# .swarm/config lives INSIDE the cwd sandbox, so a child can write it — and it
# drives both this default and the [middleware] command that runs on every
# send. Under acceptEdits that self-rewrite was reach-limited to the local
# filesystem. Under auto, a child that rewrites its own config can now also
# exfiltrate over the network in the same unattended turn — the ceiling on what
# that gap is worth to an attacker went up when this default did. Still not
# fixed here (out of scope for a default-mode change); flagged as a candidate
# to reprioritize, not as something this change resolves.
DEFAULT_PERMISSION_MODE = "auto"
# ps-blocked detection: a CLOSED set of (kind, substring) pairs matched against a
# pane's own recent text. The kind — never the matched text itself — is what ps
# renders. This is deliberate: pane text is attacker-controlled (any agent can
# print anything to its own pane), so echoing a matched excerpt into the one view
# would reopen the exact forgery class ps-model was burned on twice (render_ps,
# same file) — corruption AND impersonation are different attacks; a closed enum
# a pane's content can select FROM but never WRITE TO is immune to both. First
# match wins; order matters only in the pathological case all three appear.
BLOCKED_SIGNATURES = (
    ("trust", "trust the files in this folder"),
    ("permission", "Do you want to proceed?"),
    ("rate-limit", "resets"),  # paired check below: 'resets' alone is common prose
)
BLOCKED_KINDS = frozenset(k for k, _ in BLOCKED_SIGNATURES)
# Sender-side bound on one middleware invocation (a slow middleware must fail
# open, never stall the sender). Default; .swarm/config's [middleware] timeout
# overrides it. Env-overridable like SWARM_READY_TIMEOUT.
MIDDLEWARE_TIMEOUT = int(os.environ.get("SWARM_MIDDLEWARE_TIMEOUT", "60"))
# The ONE deliberate middleware verdict: exit 100 = HANDLED (don't queue).
# 100 sits above the shell's reserved codes (126-128, 130) and the ordinary
# error codes (1-2), so an incidental failure — crash, set -e, command not
# found — can never be misread as a deliberate HANDLED. Everything except
# 100 queues the message: exit 0 is the common pass, and every other exit,
# timeout, or kill fails OPEN.
MIDDLEWARE_HANDLED_EXIT = 100

# ---------------------------------------------------------------- primitives

def now_ms():
    return int(time.time() * 1000)


def die(msg):
    print(f"swarm: {msg}", file=sys.stderr)
    sys.exit(1)


def spawn_mandate_error():
    # The error IS the teaching moment — it is the only place most parents will ever
    # meet this idea, so it must TEACH, not scold. It teaches ONE thing: the question
    # the reason must answer.
    #
    # That question is "can I cheaply tell that this child was wrong?" — a fact about
    # the PARENT'S OWN VERIFICATION CAPACITY, which a parent can ALWAYS honestly answer
    # from the brief they are already writing, with zero knowledge of any model.
    # It is deliberately NOT "why is this model good": that framing launders a guess
    # into a decision — it demands knowledge nobody has, so it gets a confident
    # fabrication, recorded as if it were a finding. (docs/design/MODEL-FIT.md §5)
    return (
        'spawn needs --model <M> and --reason "<one clause>" — the parent '
        "chooses the child's model.\n"
        "  Ask: can you cheaply tell that this child was wrong?\n"
        "  Cheap to check (you re-read the diff, re-run the grep, the test either "
        "passes or it does not) — a small model's error costs you nothing.\n"
        "  Expensive to check (you would have to redo the reasoning to find the "
        "flaw) — pay for the strong one.\n"
        "  Say THAT, in a clause. NOT \"why is this model good\" — that question "
        "launders a guess into a decision: it demands knowledge you do not have, so "
        "you will answer it fluently and wrongly, and the wrong answer gets recorded "
        "as if it were a finding.\n"
        "  The tell: delete \"I\" from your reason. If it still makes sense, it failed "
        "— a real reason is about what YOU will do, never a property of the model.\n"
        "  tokens: opus · sonnet · fable · haiku (plus any config [models] alias — "
        "see `swarm models`). There is no default: silence is never free."
    )


def root_dir():
    return os.environ.get("SWARM_DIR") or os.path.join(os.getcwd(), ".swarm")


def my_name():
    return os.environ.get("SWARM_AGENT_ID") or "operator"


def q_dir(root, name):
    return os.path.join(root, "queue", name)


def delivered_dir(root, name):
    return os.path.join(q_dir(root, name), "delivered")


def journal_path(root, name):
    return os.path.join(root, "journal", f"{name}.md")


def agent_rec_path(root, name):
    return os.path.join(root, "agents", f"{name}.json")


def event_path(root, name):
    return os.path.join(root, "event", f"{name}.json")


def settings_dir(root):
    return os.path.join(root, "settings")


def write_atomic(path, text):
    # Inherited mechanism: tmp + rename. A concurrent reader never sees a
    # half-written file; the rename IS the state change.
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = f"{path}.tmp.{os.getpid()}"
    with open(tmp, "w") as f:
        f.write(text)
    os.replace(tmp, path)


def read_json(path):
    try:
        with open(path) as f:
            return json.load(f)
    except Exception:
        return None


def read_stdin_json():
    if sys.stdin.isatty():
        return None
    try:
        raw = sys.stdin.read()
        return json.loads(raw) if raw else None
    except Exception:
        return None


def load_agents(root):
    d = os.path.join(root, "agents")
    out = {}
    if os.path.isdir(d):
        for fn in sorted(os.listdir(d)):
            if not fn.endswith(".json"):
                continue
            r = read_json(os.path.join(d, fn))
            if r and r.get("name"):
                out[r["name"]] = r
    return out


def parents_of(agents):
    return {n: (a.get("parent") or "operator") for n, a in agents.items()}


def fmt_ts(ms):
    try:
        return time.strftime("%Y-%m-%d %H:%M:%SZ", time.gmtime(int(ms) / 1000))
    except Exception:
        return "?"


def fmt_age(ms):
    s = max(0, int(ms / 1000))
    if s < 60:
        return f"{s}s"
    if s < 3600:
        return f"{s // 60}m"
    if s < 86400:
        return f"{s // 3600}h"
    return f"{s // 86400}d"


# ---------------------------------------------------------- message delivery
# A message is a claim on one turn. These functions are the whole of delivery;
# they are pure file logic so tests can exercise them without a pane.

def relation(sender, recipient, parent_of):
    """The sender's relation to the recipient, from the recipient's seat.

    Structural sender class (design §3.4b): the header names who is speaking
    and where they stand, so a directive can never arrive framed as chatter.
    parent_of maps agent name -> parent name ('operator' at the roots).
    """
    if sender == "operator":
        return "the OPERATOR (the human at the root)"
    if parent_of.get(recipient) == sender:
        return "your parent"
    if parent_of.get(sender) == recipient:
        return "your child"
    sp = parent_of.get(sender)
    if sp and sp == parent_of.get(recipient):
        return "your sibling"
    return "another agent"


def list_waiting(root, name):
    """All waiting messages for `name`, oldest first: [(ts, fn, rec)]."""
    d = q_dir(root, name)
    out = []
    if os.path.isdir(d):
        for fn in sorted(os.listdir(d)):
            if not fn.endswith(".json"):
                continue
            p = os.path.join(d, fn)
            if not os.path.isfile(p):
                continue  # skips delivered/ and anything else odd
            r = read_json(p)
            if r and isinstance(r.get("body"), str):
                out.append((int(r.get("ts") or 0), fn, r))
    out.sort(key=lambda c: (c[0], c[1]))
    return out


def select_next(root, name):
    """The ONE message this turn: the oldest. Returns (fn, rec, n_more) or None."""
    waiting = list_waiting(root, name)
    if not waiting:
        return None
    _, fn, rec = waiting[0]
    return fn, rec, len(waiting) - 1


def count_junk(root, name):
    """Queue files that LOOK like messages but do not parse as one. Counted so
    `ps` can show them (ruling R4): an honest unknown beats an invisible file.
    Unreachable via send (atomic JSON writes); a crashed writer could strand one."""
    d = q_dir(root, name)
    n = 0
    if os.path.isdir(d):
        for fn in os.listdir(d):
            p = os.path.join(d, fn)
            if not fn.endswith(".json") or not os.path.isfile(p):
                continue
            r = read_json(p)
            if not (r and isinstance(r.get("body"), str)):
                n += 1
    return n


def delivery_head(rec, rel):
    return (f"[swarm message] from {rec.get('from', '?')} — {rel} — "
            f"sent {fmt_ts(rec.get('ts'))}\n\n")


def build_delivery(fn, rec, rel, to):
    """The exact text injected into the recipient's turn: whole, sender-headed.

    The injection is head + body, nothing else: no queue-depth trailer (ruling
    R1 — `ps` shows q=, and the stop re-ring makes a backlog self-draining),
    so an accepted message is delivered whole unconditionally.

    Returns None when not even a truncation marker fits (a hand-crafted file;
    send refuses anything that cannot fit whole): the caller must deliver
    NOTHING and leave the file queued — never delivered ≠ dropped, and a bare
    header claiming delivery would be the lie WORLD.md forbids (ruling R2).
    """
    head = delivery_head(rec, rel)
    text = head + rec.get("body", "")
    if len(text) > TURN_CAP:
        note = f"\n[truncated — full body on disk: queue/{to}/delivered/{fn}]"
        room = TURN_CAP - len(head) - len(note)
        if room <= 0:
            return None
        text = head + rec.get("body", "")[:room] + note
    return text


def send_size_error(rec, rel):
    """Refusal reason if this message cannot fit one turn's injection, else None.

    Delivery injects exactly head + body, so this check IS the delivery size:
    an accepted message is delivered whole at any queue depth. One number, no
    arithmetic for senders to learn: it fits or you send a file path.
    """
    n = len(delivery_head(rec, rel)) + len(rec.get("body", ""))
    if n > TURN_CAP:
        return (f"message too big: delivering it would take {n} chars against "
                f"the {TURN_CAP}-char turn cap — put it in a file, send the path")
    return None


def queue_put(root, rec):
    """Create rec's queue file without ever overwriting one. Two sends from
    one sender to one recipient in the same millisecond collide on
    {ts}-{from}.json, and tmp+rename would silently replace the first — the
    drop WORLD.md forbids. So claim the name with O_CREAT|O_EXCL and on
    collision bump ts by 1 and retry (bounded): the second message lands a
    millisecond later instead of vanishing. The exclusive create replaces
    tmp+rename here; a reader that catches the file mid-write skips it as
    unparseable and finds it whole next pass — delayed, never lost. Returns
    the filename; raises FileExistsError if the bump space is exhausted."""
    d = q_dir(root, rec["to"])
    os.makedirs(d, exist_ok=True)
    for _ in range(1000):
        fn = f"{rec['ts']}-{rec['from']}.json"
        try:
            fd = os.open(os.path.join(d, fn),
                         os.O_CREAT | os.O_EXCL | os.O_WRONLY)
        except FileExistsError:
            rec["ts"] += 1
            continue
        with os.fdopen(fd, "w") as f:
            f.write(json.dumps(rec))
        return fn
    raise FileExistsError(f"queue name space exhausted near {fn}")


def _looks_like_legacy_toml(path):
    """True if the first non-comment, non-blank line looks like a TOML
    section header ([spawn] / [middleware] / ...) — the signature of the
    pre-JSON .swarm/config format. Used only to decide whether a failed
    json.load deserves a loud warning instead of silent fail-open."""
    try:
        with open(path) as f:
            for raw in f:
                line = raw.strip()
                if not line or line.startswith("#"):
                    continue
                return line.startswith("[") and line.endswith("]")
    except OSError:
        pass
    return False


def read_config(root):
    """THE config reader — one file, .swarm/config, JSON. Returns a dict, or
    {} on ANY error (no file, unreadable, malformed JSON): fail-open, same
    contract read_flat_toml + the inline tomllib blocks used to give
    registered_middleware and configured_permission_mode. Those two callers
    now both go through here, so they read the same values by the same
    top-level keys (spawn/middleware) — only the parser under them changed.

    Shape (docs/design/PRODUCTIZE.md §2):
        {
          "spawn":      { "permission_mode": "auto" },
          "middleware": { "command": "...", "identity": "...", "timeout": 60 },
          "harness":    { "yoke": "/absolute/path/to/yoke" },
          "models":     { "alias": { "harness": "yoke", "model": "..." } }
        }

    Legacy detection: if the file exists, json.load fails, AND the first
    non-comment line looks like a TOML section ([spawn]/[middleware]), this
    is almost certainly the old flat-TOML config surviving an upgrade — print
    ONE stderr warning so the loss is loud, not silent, and still return {}.
    The file is never auto-rewritten (bin/swarm:113's self-modifying-config
    hazard) — the warning tells the human to convert it."""
    path = os.path.join(root, "config")
    try:
        with open(path) as f:
            return json.load(f)
    except FileNotFoundError:
        return {}
    except Exception:
        if _looks_like_legacy_toml(path):
            print(".swarm/config looks like the old TOML format; swarm now "
                  "reads JSON — see docs/design/PRODUCTIZE.md §2",
                  file=sys.stderr)
        return {}


def registered_middleware(root):
    """The send middleware, if configured: (identity, command, timeout) from
    the "middleware" key of .swarm/config (JSON, world-readable):

        {"middleware": {
            "command":  "python3 /path/to/mw.py",  # required; args allowed
                                                    # (the git core.editor
                                                    # pattern)
            "identity": "middleware",              # optional; the
                                                    # SWARM_AGENT_ID injected,
                                                    # default "middleware"
            "timeout":  60                         # optional; seconds
        }}

    ONE middleware only — a single "middleware" key; a chain belongs inside
    the middleware, not in the tool. The tool carries NO policy about what
    the middleware does. None on ANY error — no file, no key, no command
    key, unparseable — means no middleware, and cmd_send is byte-identical to
    today (fail-open)."""
    try:
        conf = read_config(root)
        mw = conf.get("middleware") or {}
        command = str(mw.get("command") or "").strip()
        if not command:
            return None
        identity = str(mw.get("identity") or "").strip() or "middleware"
        timeout = int(mw.get("timeout") or MIDDLEWARE_TIMEOUT)
        return identity, command, timeout
    except Exception:
        return None


def configured_permission_mode(root):
    """The operator's chosen default permission mode, if set, from the
    "spawn" key of .swarm/config:

        {"spawn": {"permission_mode": "plan"}}   # e.g. an operator who wants
                                                  # every child to start
                                                  # cautious, overriding the
                                                  # DEFAULT_PERMISSION_MODE
                                                  # built into swarm

    None on ANY error — no file, no key, no permission_mode, unparseable —
    meaning "use DEFAULT_PERMISSION_MODE", same fail-open posture as
    registered_middleware. NOT validated against PERMISSION_MODES here — the
    one caller (cmd_spawn) validates whatever value it ends up with,
    regardless of source, so there is exactly one place a bad mode is
    rejected."""
    try:
        conf = read_config(root)
        sp = conf.get("spawn") or {}
        mode = str(sp.get("permission_mode") or "").strip()
        return mode or None
    except Exception:
        return None


def emit_hook_output(obj):
    """Write hook JSON to stdout and WAIT for it to drain. True = delivered.

    The G17 discipline, inherited: side effects are conditional on the bytes
    actually leaving. Python's write()/flush() block until the pipe took the
    bytes or raise — unlike node, which discarded its queued stdout at exit
    and silently destroyed every payload over the ~64 KiB pipe buffer.
    """
    try:
        sys.stdout.write(json.dumps(obj))
        sys.stdout.flush()
        return True
    except OSError:
        # Point fd 1 at /dev/null so the interpreter's own exit-flush of the
        # broken pipe cannot fail after our exit(0) — without this, python
        # dies with status 120 and the "any error -> exit 0" promise is false
        # (ruling R3). The undelivered bytes are already accounted for: the
        # caller keeps the message queued.
        try:
            os.dup2(os.open(os.devnull, os.O_WRONLY), sys.stdout.fileno())
        except OSError:
            pass
        return False


def next_delivery(root, name, parent_of):
    """The queue head as it would be delivered: (fn, ctx). ctx is None for an
    undeliverable head (ruling R2), the whole result is None on an empty queue.
    The ONE definition of deliverability — deliver_once injects with it and the
    stop re-ring rings by it, so they cannot disagree (ruling R7)."""
    sel = select_next(root, name)
    if not sel:
        return None
    fn, rec, _ = sel
    return fn, build_delivery(fn, rec,
                              relation(rec.get("from", "?"), name, parent_of),
                              name)


def deliver_once(root, name, parent_of, emit):
    """Deliver at most ONE message: emit it, and move it to delivered/ ONLY
    after the emit reports the bytes drained. On a failed emit the file stays
    put and is offered whole again next turn — the safe direction to fail."""
    nd = next_delivery(root, name, parent_of)
    if not nd:
        return False
    fn, ctx = nd
    if ctx is None:
        # Undeliverable (ruling R2): emit nothing, move nothing. The file
        # stays visible in `ps` q= — and it blocks the queue behind it, which
        # is deliberate: silently skipping it would hide a file that only a
        # hand-crafted write can produce.
        return False
    ok = emit({"hookSpecificOutput": {"hookEventName": "UserPromptSubmit",
                                      "additionalContext": ctx}})
    if ok:
        try:
            os.makedirs(delivered_dir(root, name), exist_ok=True)
            os.replace(os.path.join(q_dir(root, name), fn),
                       os.path.join(delivered_dir(root, name), fn))
        except OSError:
            pass  # worst case: re-delivered next turn; never lost
    return ok


# ----------------------------------------------------------- restore payload

def journal_tail(path, cap=JOURNAL_TAIL_CAP):
    """The journal's last `cap` chars; a truncation marker points at the rest."""
    try:
        with open(path) as f:
            text = f.read()
    except OSError:
        return ""
    if len(text) <= cap:
        return text
    return (f"[…journal truncated to its last {cap} chars — "
            f"read the full file: {path}]\n") + text[-cap:]


def build_restore(task_text, jpath, source):
    """SessionStart injection: the original task + the journal tail."""
    resumed = ("AFTER A CONTEXT COMPACTION — your working memory was just "
               "summarized away; your journal is your most reliable record"
               if source == "compact" else "a fresh session")
    tail = journal_tail(jpath)
    return (f"[swarm restore] You are resuming {resumed}.\n\n"
            f"--- YOUR ORIGINAL TASK ---\n{task_text}\n\n"
            f"--- YOUR JOURNAL (tail) ---\n{tail or '(journal is empty)'}\n\n"
            f"Continue from where the journal leaves off, and keep appending "
            f"to it as you work.")


# --------------------------------------------------------------- event facts

def last_assistant_text(transcript_path):
    """The last assistant words from the transcript, whitespace-collapsed."""
    try:
        if not transcript_path or not os.path.exists(transcript_path):
            return ""
        with open(transcript_path) as f:
            lines = [l for l in f.read().split("\n") if l]
        for line in reversed(lines):
            try:
                o = json.loads(line)
            except Exception:
                continue
            msg = o.get("message")
            if not msg or msg.get("role") != "assistant":
                continue
            c = msg.get("content")
            if isinstance(c, str):
                text = c
            elif isinstance(c, list):
                text = " ".join(b.get("text", "") for b in c
                                if isinstance(b, dict) and b.get("type") == "text")
            else:
                text = ""
            text = " ".join(text.split())
            if text:
                return text
        return ""
    except Exception:
        return ""


def record_event(root, name, kind, last_words, ts):
    """Overwrite the ONE per-agent event fact: event name, ts, last words.
    No history, no done/question/blocked taxonomy, no heuristics — `ps` shows
    the fact and the pane is one command away."""
    write_atomic(event_path(root, name), json.dumps(
        {"event": kind, "ts": ts, "last_words": (last_words or "")[:LAST_WORDS_CAP]}))


# ------------------------------------------------------------------ ps view

def render_ps(agents, live, queues, events, me_name, op_mail, now, junk=None,
              blocked=None):
    """The one view. Pure: every input is a plain value, so it tests offline.

    agents:  {name: record}         live:  set of live pane ids, or None (herdr unknown)
    queues:  {name: waiting-count}  events:{name: event fact or None}
    op_mail: [(from, ts)] waiting operator messages, oldest first
    junk:    {name: unparseable-queue-file count} (ruling R4; may be None)
    blocked: {name: 'trust'|'permission'|'rate-limit'} (may be None; absence
             for a name means not blocked, same convention as junk)

    Dead agents render compactly — names only, one shared line (ruling R5):
    the living tree stays one screen however long the swarm's history grows.
    A live agent under a dead parent reattaches to its nearest living ancestor
    so hiding the dead never orphans the living.

    A non-empty 'model' means the agent was PINNED with --model at spawn, and ps
    renders it in a slot of its own: `model=opus`. An empty one means the agent
    was NOT pinned: the record says nothing about which model is actually running
    (a launcher with no --model execs bare `claude`, and nothing propagates from
    the spawner), so ps says nothing. It is a fact about the spawn, not the model.

    The pin gets its OWN slot because any agent can `swarm spawn --model you`,
    and a pin rendered as `(you)` would be byte-identical to the marker naming
    the reader. `(you)` is load-bearing for IDENTITY, so nothing attacker-shaped
    may share its syntax — `model=you` is self-evidently a claim about a model.

    'blocked' carries the SAME hazard, sharper: its source is live pane text,
    which an agent fully controls (it is that agent's own terminal). The value
    in the dict must already be one of the three closed kinds — classify_blocked
    guarantees that upstream — and render_ps trusts the dict as-is; it never
    looks at pane text itself and never prints anything from the dict except
    the kind. A blocked pane replaces its idle clause with `[blocked: kind]`
    rather than adding to it: a wedged session's idle time is not additional
    information once the reason is known, and keeping both would let a stale
    idle age read as reassuring ("only 2m") beside the fact that it will never
    move again on its own.
    """
    junk = junk or {}
    blocked = blocked or {}
    lines = []
    if op_mail:
        lines.append(f"operator — {len(op_mail)} message(s) waiting for the human "
                     f"(queue/operator/):")
        for frm, ts in op_mail:
            lines.append(f"    from {frm}, {fmt_age(now - ts)} ago")
    else:
        lines.append("operator — no waiting mail")

    def is_dead(a):
        return live is not None and a.get("pane") not in live
    dead = sorted(n for n, a in agents.items() if is_dead(a))
    shown_set = {n for n in agents if n not in dead}

    def eff_parent(n):
        # nearest non-dead ancestor; a chain that leaves the records keeps its
        # last (unknown) name so the orphan line below can report it
        p = agents[n].get("parent") or "operator"
        seen = set()
        while p in agents and p not in shown_set and p not in seen:
            seen.add(p)
            p = agents[p].get("parent") or "operator"
        return p

    kids = {}
    for n in shown_set:
        kids.setdefault(eff_parent(n), []).append(n)
    for k in kids:
        kids[k].sort()

    def q_of(n):
        return f"q={queues.get(n, 0)}" + (f"+{junk[n]}?" if junk.get(n) else "")

    def model_of(n):
        # A non-empty model means PINNED with --model at spawn; empty means NOT
        # pinned, which says nothing about the model actually running — so ps
        # says nothing.
        #
        # It renders as `model=x`, in a slot of its own. NOT as `(x)` beside
        # `(you)` — that was tried and it is unfixable. In a swarm ANY agent can
        # run `swarm spawn --model <anything>`, so the pin is ATTACKER-controlled
        # text, and `--model you` renders `bait (you)`: byte-identical to the
        # marker that answers "which of these is ME?". No sanitizer saves this,
        # because `you` is CLEAN input — it forges the marker only because
        # `(you)` and `(opus)` ARE THE SAME SYNTAX. You cannot escape your way
        # out of a namespace collision; you leave the namespace. `model=you` is
        # self-evidently a claim about a MODEL, so the forge defeats itself.
        #
        # The value is still cleaned, because the record is written verbatim and
        # the VIEW must protect itself (the record keeps the truth): collapse
        # whitespace (a newline would forge a tree row), drop control characters
        # (ANSI), drop the glyphs that do structural work here, cap the length.
        # Same layer, same reason, as LAST_WORDS_CAP.
        #
        # A cut id ends in '…', because 'claude-haiku-4-5-2025100' is a LIE that
        # looks like an id while 'claude-haiku-4-5-2025…' is visibly a fragment.
        # The renderer must never state a claim the record does not support, and
        # a plausible-but-wrong id is worse than no id at all.
        m = str(agents[n].get("model") or "")
        m = "".join(c for c in m
                    if c.isprintable() and not c.isspace()
                    and c not in MODEL_STRUCTURAL)
        if len(m) > MODEL_CAP:
            m = m[:MODEL_CAP - 1] + "…"
        return f" model={m}" if m else ""

    def idle_of(name):
        # A blocked kind, IF it is one of the three this build knows how to
        # render, replaces the idle clause outright — see render_ps's
        # docstring for why replace, not append. Anything else in the dict
        # (a future kind this build doesn't recognize, or a corrupt value)
        # is treated as absent: the view must never print a kind it cannot
        # vouch for, same reasoning as model_of's exclude-list.
        kind = blocked.get(name)
        if kind in BLOCKED_KINDS:
            return f"[blocked: {kind}]"
        ev = events.get(name)
        return f"idle {fmt_age(now - ev['ts'])}" if ev and ev.get("ts") else "idle ?"

    def walk(name, prefix, is_last):
        a = agents[name]
        branch = "└─ " if is_last else "├─ "
        you = " (you)" if name == me_name else ""
        ev = events.get(name)
        alive = "live" if live is not None else "?"
        lines.append(f"{prefix}{branch}{name}{you}{model_of(name)} "
                     f"[{alive}] {q_of(name)} {idle_of(name)}")
        if ev and ev.get("last_words"):
            cont = "   " if is_last else "│  "
            lines.append(f'{prefix}{cont}   last: "{ev["last_words"][:80]}"')
        ch = kids.get(name, [])
        for i, c in enumerate(ch):
            walk(c, prefix + ("   " if is_last else "│  "), i == len(ch) - 1)

    roots = kids.get("operator", [])
    if not agents:
        lines.append("(no agents)")
    for i, r in enumerate(roots):
        walk(r, "", i == len(roots) - 1)
    # A live agent whose parent chain ends at an unknown name still renders
    # (flat), so nothing alive can be invisible to the one view.
    in_tree = set()

    def collect(n):
        in_tree.add(n)
        for c in kids.get(n, []):
            collect(c)
    for r in roots:
        collect(r)
    for n in sorted(shown_set - in_tree):
        a = agents[n]
        alive = "live" if live is not None else "?"
        lines.append(f"?─ {n}{model_of(n)} [parent {a.get('parent', '?')} unknown] "
                     f"[{alive}] {q_of(n)}")
    if dead:
        lines.append(f"dead: {', '.join(dead)}")
    return "\n".join(lines)


def subtree(agents, root_name):
    """root_name + every descendant, by walking recorded parent edges."""
    kids = {}
    for n, a in agents.items():
        kids.setdefault(a.get("parent") or "operator", []).append(n)
    out, stack, seen = [], [root_name], set()
    while stack:
        x = stack.pop()
        if x in seen:
            continue
        seen.add(x)
        if x in agents:
            out.append(x)
        stack.extend(kids.get(x, []))
    return out


def classify_blocked(pane_text):
    """Pure. pane_text -> one of 'trust' | 'permission' | 'rate-limit' | None.

    pane_text is UNTRUSTED: it is whatever is currently visible in an agent's
    own pane, and any agent can print anything to its own pane. This function
    is the ONLY thing allowed to look at it, and it returns a value from a
    CLOSED set — never a substring of the input. That is what makes the result
    safe to hand to render_ps: a fixed enum cannot forge a tree row, a fake
    `dead:` line, or the `(you)` marker, no matter what the pane contains. See
    BLOCKED_SIGNATURES; the 'rate-limit' kind additionally requires 'limit' to
    co-occur with 'resets', since 'resets' alone is common enough prose to
    false-positive on an agent's own unrelated output.
    """
    if not pane_text:
        return None
    for kind, needle in BLOCKED_SIGNATURES:
        if needle not in pane_text:
            continue
        if kind == "rate-limit" and "limit" not in pane_text:
            continue
        return kind
    return None


# ---------------------------------------------------------------- herdr edge
# Everything below talks to a live pane. Exempt from unit tests by the brief;
# kept thin so the logic above stays pure.

def herdr_json(args, timeout=15):
    try:
        p = subprocess.run(["herdr"] + args, capture_output=True, text=True,
                           timeout=timeout)
        return json.loads(p.stdout)
    except Exception:
        return None


def live_pane_set():
    d = herdr_json(["pane", "list"])
    if not d:
        return None  # herdr unreachable: liveness unknown, never asserted
    return {p.get("pane_id") for p in d.get("result", {}).get("panes", [])
            if p.get("pane_id")}


def listed_ids(kind, timeout=15):
    """The live set of tab_id (kind="tab") or pane_id (kind="pane") from
    herdr, or None if herdr is unreachable — never asserted as empty."""
    d = herdr_json([kind, "list"], timeout=timeout)
    if d is None:
        return None
    key = "tab_id" if kind == "tab" else "pane_id"
    plural = "tabs" if kind == "tab" else "panes"
    return {item.get(key) for item in d.get("result", {}).get(plural, [])}


def wait_gone(kind, ident, timeout=3.0, interval=0.2, poll_timeout=1.0):
    """Poll `herdr <kind> list` until ident is absent from it. `kind` is
    "tab" or "pane". Returns True once the id is verifiably gone (including
    if it was already gone on the first check), False if the timeout
    expires with the id still — or ambiguously, herdr-unreachable — present.

    A close call's return code fires before herdr's teardown does — the id
    can still show up in `list` seconds after `close` returned 0. Only a
    listing that no longer contains the id is proof; the return code is a
    claim, not the fact (PHILOSOPHY §4). herdr-unreachable is treated as
    still-present, not gone: silence must never be read as success.

    Each poll's own subprocess is capped at poll_timeout, well under
    `timeout`: a herdr that hangs (rather than erroring) must not let one
    poll blow the overall wait past its documented bound.
    """
    t0 = time.time()
    while True:
        ids = listed_ids(kind, timeout=poll_timeout)
        if ids is not None and ident not in ids:
            return True
        if time.time() - t0 >= timeout:
            return False
        time.sleep(interval)


def pane_prompt_line(pane):
    try:
        p = subprocess.run(["herdr", "pane", "read", pane, "--source", "visible",
                            "--lines", "40"], capture_output=True, text=True,
                           timeout=10)
        rows = [l for l in p.stdout.splitlines() if "❯" in l]
        return rows[-1].split("❯", 1)[1].strip() if rows else ""
    except Exception:
        return ""


def pane_text(pane):
    """Raw visible text of a pane, best-effort. A blocking dialog (trust,
    permission, rate-limit) is prose, not a `❯`-anchored input line, so this
    reads the whole visible window rather than reusing pane_prompt_line's
    narrower anchor."""
    try:
        p = subprocess.run(["herdr", "pane", "read", pane, "--source", "visible",
                            "--lines", "40"], capture_output=True, text=True,
                           timeout=10)
        return p.stdout
    except Exception:
        return ""


def blocked_candidates(agents, live, events, now, threshold_ms=120_000):
    """Which agents are worth the cost of a live pane read: live, and either no
    event fact yet or idle past threshold_ms. A pane that Stopped recently is
    almost certainly not wedged on a prompt (Stop only fires on a real turn
    boundary) — skip it and save the read. Pure; the read itself is not."""
    out = []
    for n, a in agents.items():
        if live is not None and a.get("pane") not in live:
            continue  # dead panes have nothing to read
        ev = events.get(n)
        if ev and ev.get("ts") and now - ev["ts"] < threshold_ms:
            continue  # recently active; a wedge takes at least this long to matter
        out.append(n)
    return out


def read_blocked(root, agents, live, events, now):
    """cmd_ps's live edge for blocked-detection: pane-reads ONLY the agents
    blocked_candidates names (never the whole fleet unconditionally — most
    ps calls see zero candidates once a swarm is past its spawn burst), in a
    bounded thread pool so N candidates cost one round-trip's wall time, not
    N. Returns {name: 'trust'|'permission'|'rate-limit'} for panes that
    matched; agents with no match are simply absent (not None) — render_ps
    treats missing == not blocked."""
    cands = blocked_candidates(agents, live, events, now)
    if not cands:
        return {}
    result = {}
    with concurrent.futures.ThreadPoolExecutor(max_workers=min(8, len(cands))) as ex:
        futs = {ex.submit(pane_text, agents[n]["pane"]): n for n in cands
                if agents[n].get("pane")}
        for f in concurrent.futures.as_completed(futs):
            n = futs[f]
            try:
                kind = classify_blocked(f.result())
            except Exception:
                kind = None
            if kind:
                result[n] = kind
    return result


def ring_doorbell(pane, text="check queue"):
    """Submit a short non-empty prompt to a pane so UserPromptSubmit fires and
    `deliver` runs. send-text arrives via bracketed paste, so wait for the
    prompt box to settle before Enter, then confirm it drained (bounded
    retries). Best-effort by contract: the queue file is already durable, so
    every failure here only delays pickup to the next natural turn."""
    try:
        p = subprocess.run(["herdr", "pane", "send-text", pane, text],
                           capture_output=True, timeout=10)
        if p.returncode != 0:
            return False
    except Exception:
        return False
    prev = None
    for _ in range(20):
        cur = pane_prompt_line(pane)
        if cur and cur == prev:
            break
        prev = cur
        time.sleep(0.2)
    for _ in range(5):
        try:
            p = subprocess.run(["herdr", "pane", "send-keys", pane, "Enter"],
                               capture_output=True, timeout=10)
            if p.returncode != 0:
                return False
        except Exception:
            return False
        time.sleep(0.4)
        if pane_prompt_line(pane) == "":
            return True
        time.sleep(0.3)
    return True  # text + Enter went out; treat as rung (queue is durable anyway)


def ring_doorbell_once(pane, text="check queue"):
    """One-attempt ring for the Stop hook, which blocks its own agent's next
    turn until it returns: one send-text, a short pause for the paste to land,
    one Enter — never a pane read, never a settle loop. Field evidence
    (2026-07-10): the full ring's settle loop spun ~20 x 10s herdr reads
    against a loaded pane, freezing the agent ~3 minutes while deliverable
    mail waited. A ring skipped or missed here is degradation, never loss —
    the queue file is durable and the next natural turn delivers it."""
    try:
        p = subprocess.run(["herdr", "pane", "send-text", pane, text],
                           capture_output=True, timeout=5)
        if p.returncode != 0:
            return False
        time.sleep(0.5)
        p = subprocess.run(["herdr", "pane", "send-keys", pane, "Enter"],
                           capture_output=True, timeout=5)
        return p.returncode == 0
    except Exception:
        return False


# -------------------------------------------------------------- hook verbs

def cmd_deliver():
    # UserPromptSubmit. Bulletproof: any error -> exit 0, no output, turn intact.
    if my_name() == "operator":
        sys.exit(0)
    read_stdin_json()  # drain the payload; delivery needs nothing from it
    try:
        root = root_dir()
        deliver_once(root, my_name(), parents_of(load_agents(root)),
                     emit_hook_output)
    except Exception:
        pass
    sys.exit(0)


def cmd_event(kind):
    # Stop/Notification. Record the fact; on Stop with a non-empty queue,
    # re-ring our own doorbell so the queue keeps draining while we idle.
    if kind not in ("stop", "notification"):
        die(f"event: unknown kind '{kind}' (stop | notification)")
    if my_name() == "operator":
        sys.exit(0)
    payload = read_stdin_json() or {}
    root, name = root_dir(), my_name()
    try:
        record_event(root, name, kind,
                     last_assistant_text(payload.get("transcript_path") or ""),
                     now_ms())
    except Exception:
        pass
    # >>> THE ONE UNPROVEN MECHANISM (design §6.3): the stop re-ring. <<<
    # One-per-turn needs the queue to keep draining after the agent goes idle:
    # on Stop, ring our OWN pane's doorbell — the single-attempt variant, not
    # send's settle-and-confirm ring: this hook blocks the agent's next turn,
    # so it must return fast rather than poll a busy pane. Ring only if the
    # head is DELIVERABLE (ruling R7): ringing for a head that
    # build_delivery refuses would loop forever (ring, empty turn, Stop, still
    # queued, ring...) burning tokens with nobody watching. If the ring proves
    # unreliable, later messages stall until the next natural turn —
    # degradation, never loss: the queue files are durable and `deliver` picks
    # them up whenever the next turn comes.
    if kind == "stop":
        try:
            nd = next_delivery(root, name, parents_of(load_agents(root)))
            if nd and nd[1] is not None:
                rec = read_json(agent_rec_path(root, name))
                if rec and rec.get("pane"):
                    ring_doorbell_once(rec["pane"])
        except Exception:
            pass
    sys.exit(0)


def cmd_restore():
    # SessionStart (startup or post-compaction): original task + journal tail.
    if my_name() == "operator":
        sys.exit(0)
    payload = read_stdin_json() or {}
    root, name = root_dir(), my_name()
    try:
        task = ""
        try:
            with open(os.path.join(settings_dir(root), f"{name}.task")) as f:
                task = f.read()
        except OSError:
            pass
        emit_hook_output({"hookSpecificOutput": {
            "hookEventName": "SessionStart",
            "additionalContext": build_restore(task, journal_path(root, name),
                                               payload.get("source") or "startup")}})
    except Exception:
        pass
    sys.exit(0)


# --------------------------------------------------------------- CLI verbs

def claim_name(root, name):
    """Atomically claim `name` by creating its journal — the tombstone. The
    journal file existing IS 'this name was used'; no ledger, no suffixing.
    Raises FileExistsError on a name ever used."""
    jpath = journal_path(root, name)
    os.makedirs(os.path.dirname(jpath), exist_ok=True)
    fd = os.open(jpath, os.O_CREAT | os.O_EXCL | os.O_WRONLY)
    return fd


def spawn_header(name, parent):
    parent_desc = ("the human operator" if parent == "operator"
                   else f"agent `{parent}`")
    return (
        f"You are agent {name} in a swarm — a tree of Claude agents. Your parent, "
        f"who judges and approves your work: {parent_desc}.\n"
        f"You have the `swarm` CLI: "
        f"`swarm spawn <name> \"<task>\" --model <M> --reason \"<why>\"` to delegate, "
        f"`swarm send <name>` to message (a message is a claim on one turn), "
        f"`swarm ps` to see the whole tree, `swarm world` for the full contract — "
        f"read it before coordinating others.\n"
        # This sentence is the mandate's real delivery vehicle. The USAGE string is read
        # by whoever types `swarm`; THIS is injected into every child that will ever
        # spawn — it is where a parent learns what spawning even looks like. The old
        # version showed the bare no-flag form, and 142 of 143 spawns copied it exactly.
        # Teach the QUESTION here, not just the flag: a flag gets filled in, a question
        # gets answered.
        f"**--model and --reason are REQUIRED** — you choose your child's model, and "
        f"the reason answers ONE question: *can you cheaply tell that this child was "
        f"wrong?* If you will re-read its diff or re-run its grep anyway, a cheap "
        f"model's error costs you nothing — pin `sonnet`. If catching a flaw would "
        f"mean redoing the reasoning yourself, pay for `opus`. Say THAT — not why the "
        f"model is good (you do not know, and a guess dressed as a reason is worse "
        f"than none). Tokens: opus sonnet fable haiku, plus any config "
        f"[models] alias (see `swarm models`). There is no default.\n\n"
        f"Your duties (briefed, not enforced): keep your journal at "
        f".swarm/journal/{name}.md — append timestamped entries in your own words "
        f"as you work, and always before going idle; a reconciliation entry names "
        f"its falsifier (the observation that would show you are off track). "
        f"Report to your parent when done or stuck. Produce concrete, inspectable "
        f"artifacts — all work, including yours, is judged by reading it, never "
        f"by claims.\n\n"
        f"Delegate by default: keep judgment, verification, and glue; spawn "
        f"children for the work itself — doing parallelizable work serially "
        f"yourself is off-track. Each reconciliation, ask whether the tree still "
        f"matches the remaining work and whether your span still matches your "
        f"attention: spawn what is missing, close harvested children whose "
        f"workstream is done, split what you cannot attend, absorb what no "
        f"longer earns its layer — keep a child only if you can name its next "
        f"task. "
        f"When you dispatch to a name you have dispatched to before, say what "
        f"recurred, in the same entry — this is how repeated shapes of work "
        f"become visible to anyone reading your journal. "
        f"You are over span when you can no longer name each child's state and "
        f"the next artifact you expect from it without re-reading. If a spawn "
        f"would take you past that, spawn a coordinator and split the stream "
        f"instead; when a coordinator's stream shrinks to what you can hold "
        f"directly, absorb it — harvest, close, take the survivors. The "
        f"operator's span is theirs to declare and yours to protect: never let "
        f"the tree press more direct attention on the operator than they asked "
        f"for. "
        f"When you judge a child's work, judge its delegation too. Closing a "
        f"subtree to re-form a better shape is normal and encouraged — harvest "
        f"its journal and artifacts first, journal the reason; files survive "
        f"close, and burned names are the record working as designed.\n\n"
        f"--- YOUR TASK ---\n")


def herdr_run_path(launcher):
    """Pure. `herdr pane run` TYPES its command argument into the pane's
    shell — so the path must survive TWO transforms in this order: herdr's
    own one-leading-slash strip (HERDR-BUG SHIM, confirmed present in herdr
    0.7.3, the version installed on the machine this was verified on;
    earliest known-affected version not established — do not read "0.7.1"
    elsewhere as an upper bound, it named the version first observed, not
    the version fixed: `herdr pane run` strips exactly ONE leading '/' from
    the command it types into the pane, so an absolute launcher path arrives
    relative and the shell can't find it), and then the target shell parsing
    whatever survives the strip as a word (so a space, $, quote, backtick,
    paren, or semicolon in the path must not split or inject).

    A naive fix picks one transform and breaks the other. Doubling the slash
    (the old shim) survives the strip but is unquoted — a space in the path
    still splits it into two shell words. Quoting first breaks the strip
    instead: shlex.quote('/a b/c') -> "'/a b/c'" — its first character is a
    QUOTE, not '/', so herdr's strip eats the quote and leaves an unbalanced
    string.

    The construction that survives both, in order: quote the launcher with
    shlex.quote (safe as a single shell word for any content), THEN prepend
    a bare '/' OUTSIDE the quoting, only when the launcher is absolute.
    Concretely, for launcher = '/a b/c':
        shlex.quote(launcher)  -> "'/a b/c'"        (a valid, complete shell word)
        '/' + that             -> "/'/a b/c'"        (what herdr_run_path returns)
        herdr's strip (eats the leading '/', which is now OUTSIDE the quotes)
                                -> "'/a b/c'"         (the untouched quoted word)
        shell parses this      -> /a b/c              (original path, exact)
    Verified empirically against a real herdr 0.7.3 pane with a path
    containing a space, and against `shlex.split` round-trips for $, ', ",
    `, (), ;, and unicode, individually and combined.
    A relative launcher path never hits the strip (it doesn't start with
    '/'), so it is quoted but not slash-prefixed.
    Delete the slash-prepending half of this function once herdr fixes
    pane-run's arg handling; shlex.quote alone is correct once the strip is
    gone."""
    quoted = shlex.quote(launcher)
    return "/" + quoted if launcher.startswith("/") else quoted


CLAUDE_JSON_TRUST_KEY = "hasTrustDialogAccepted"


def pre_trust_entry(config, abspath):
    """Pure. config: the parsed contents of ~/.claude.json (or {} if missing/
    corrupt). abspath: the absolute cwd a throwaway agent is about to launch
    into. Returns a NEW config dict with config['projects'][abspath][KEY] set
    True, touching NOTHING else — not other keys on an existing entry, not
    other projects. ~/.claude.json is Claude Code's own live, global,
    per-machine settings file (111 real project entries observed on one dev
    machine, holding real usage/session history); this function's whole job
    is to be safe to call against that file, so it never does a blanket
    dict-merge or rewrite — only ever adds or flips the one key this feature
    owns. An existing entry (a dir a human already uses normally) has its
    other keys preserved byte-for-byte; only the trust key is touched, and
    only set to True, never to False (this function only grants, never
    revokes — a caller wanting to un-trust a dir must do that some other way,
    deliberately)."""
    out = dict(config)
    projects = dict(out.get("projects") or {})
    entry = dict(projects.get(abspath) or {})
    entry[CLAUDE_JSON_TRUST_KEY] = True
    projects[abspath] = entry
    out["projects"] = projects
    return out


def write_launcher(launcher, statusfile, settings, taskfile, model, permission_mode):
    # Inherited mechanism (G14): the task lives in a FILE; herdr only ever sees
    # the launcher's path — zero escaping, zero multibyte on argv. The launcher
    # pre-flights and records its outcome to the status file, so spawn can tell
    # a started harness from a dead one by a fired signal, not a screen scrape.
    #
    # permission_mode is ALWAYS passed (never omitted like `model` can be):
    # without it every child inherits Claude Code's own default, which is the
    # manual/ask-every-time mode — exactly the wedge this parameter exists to
    # fix. There is no "no opinion" spawn; cmd_spawn always resolves one
    # (--permission-mode, else .swarm/config, else DEFAULT_PERMISSION_MODE)
    # before calling here.
    claude_cmd = (f'claude --settings {shlex.quote(settings)} '
                  f'--permission-mode {shlex.quote(permission_mode)}')
    if model:
        claude_cmd += f' --model {shlex.quote(model)}'
    claude_cmd += ' "$PROMPT"'
    lines = [
        "#!/usr/bin/env bash",
        "set -uo pipefail",
        f"STATUS={shlex.quote(statusfile)}",
        "if ! command -v claude >/dev/null 2>&1; then",
        '  echo "failed: claude not found on PATH" > "$STATUS"',
        '  echo "[swarm] ERROR: claude not found on PATH in this pane" >&2',
        "  exec bash",
        "fi",
        f"if [ ! -r {shlex.quote(settings)} ]; then",
        f"  echo failed: settings unreadable: {shlex.quote(settings)} > \"$STATUS\"",
        "  exec bash",
        "fi",
        f'PROMPT="$(cat {shlex.quote(taskfile)})"',
        'echo "launching" > "$STATUS"',
        claude_cmd,
        "rc=$?",
        'if [ "$rc" -ne 0 ]; then echo "failed: claude exited code $rc" > "$STATUS"; fi',
        "exec bash",  # keep the pane inspectable after claude ends
    ]
    with open(launcher, "w") as f:
        f.write("\n".join(lines) + "\n")
    os.chmod(launcher, 0o755)


def pre_trust_dir(abspath):
    """Best-effort. Flips ~/.claude.json's trust bit for abspath so a claude
    session launched there skips the workspace-trust prompt. Read-modify-write
    of a live, global, per-machine file OTHER Claude Code sessions may also be
    writing — never crash spawn over this (same posture as herdr_json): a
    missed pre-trust just means the old behavior (a prompt), not a broken
    spawn. See pre_trust_entry for the actual patch logic; this function is
    only the disk I/O around it. Returns True if the write is believed to have
    landed, False otherwise (best-effort; not a strong guarantee under a
    concurrent writer, since there is no lock on this file and none is ours to
    add — CLI-external tools are expected to lose the occasional race to the
    editor that owns the file)."""
    path = os.path.expanduser("~/.claude.json")
    try:
        with open(path) as f:
            config = json.load(f)
    except Exception:
        config = {}
    try:
        updated = pre_trust_entry(config, abspath)
        write_atomic(path, json.dumps(updated))
        return True
    except Exception:
        return False


OPENCODE_AUTH_PATH = os.path.expanduser("~/.local/share/opencode/auth.json")


def resolve_model_alias(model, conf):
    """C3 (docs/design/PRODUCTIZE.md §3): --model always names an alias, and
    the alias names its harness EXPLICITLY — there is no slash heuristic and
    no bare-token-with-slash path. Returns (harness, resolved_model) or
    (None, None) if `model` names neither a config alias nor a builtin.

    Resolution order:
      1. A config [models] alias — SHADOWS a same-named builtin (config wins).
      2. One of the four implicit builtin Claude tokens (opus/sonnet/fable/
         haiku) — resolves to {harness: "claude", model: <token>} with NO
         config entry needed. This is the ONE implicit resolution kept from
         today's zero-config Claude spawn; every other token must be an
         explicit alias naming its harness."""
    aliases = conf.get("models") or {}
    entry = aliases.get(model)
    if entry is not None:
        harness = str(entry.get("harness") or "")
        resolved = str(entry.get("model") or "")
        return harness, resolved
    if model in SPAWN_MODELS:
        return "claude", model
    return None, None


def provider_auth_refusal(model):
    """Cheap, best-effort check: is the provider prefix of a yoke `model`
    (e.g. "zai-coding-plan" out of "zai-coding-plan/glm-5.1") present in
    opencode's own auth store? Returns a one-sentence refusal string if NOT
    authed, or None if authed / the check can't be done cheaply (fail-open —
    an unreadable or absent auth.json must never block a spawn that would
    otherwise have worked; yoke itself will surface a real auth failure).
    Deferred per the design: this reads opencode's auth store as a courtesy
    early check, not a guarantee — the authoritative check is opencode's own,
    inside the fork, which this PR does not reach into."""
    if "/" not in model:
        return None
    provider = model.split("/", 1)[0]
    try:
        with open(OPENCODE_AUTH_PATH) as f:
            authed = json.load(f)
    except Exception:
        return None
    if provider in authed:
        return None
    known = ", ".join(sorted(authed)) or "(none)"
    return (f"provider '{provider}' (from model '{model}') is not authed in "
            f"opencode ({OPENCODE_AUTH_PATH}) — authed providers: {known}. "
            f"Run opencode's auth login for '{provider}' first.")


def dispatch_yoke(name, task, model, parent, reason, root, yoke_path, conf,
                   permission_mode):
    """C3 yoke path (docs/design/PRODUCTIZE.md §3): subprocess (NOT exec —
    bin/swarm stays alive to report failure and propagate exit code) the
    installed `yoke` command. yoke claims its own tombstone/agent-record and
    does its own herdr tab; bin/swarm's job here is purely to translate its
    own flags into yoke's argv and pass stdout/stderr + exit code through."""
    argv = [yoke_path, name, task,
            "--model", model,
            "--parent", parent,
            "--reason", reason,
            "--swarm-dir", root]
    yoke_fork = (conf.get("harness") or {}).get("yoke_fork") or os.environ.get("YOKE_FORK")
    if yoke_fork:
        argv += ["--yoke-fork", yoke_fork]
    # C4: thread the (already-validated, already-yoke-compatible) permission
    # mode through. PR3 only THREADS the flag + refuses ask-a-human modes
    # (done above, before dispatch); the opencode permission-map translation
    # under this flag is PR4/yoke's job — if the installed yoke doesn't yet
    # accept --permission-mode, this flag reaching it as an unknown flag is a
    # yoke-side gap for PR4 to close, not something bin/swarm silently drops.
    argv += ["--permission-mode", permission_mode]
    p = subprocess.run(argv)
    if p.returncode != 0:
        ws = os.path.join(os.path.dirname(os.path.realpath(yoke_path)),
                           f"ws-{name}")
        log = os.path.join(ws, "boot.log")
        print(f"swarm: spawn failed (yoke exited {p.returncode}) — check the "
              f"boot log at {log}", file=sys.stderr)
    sys.exit(p.returncode)


def cmd_spawn(argv):
    if len(argv) < 2:
        die('spawn needs: swarm spawn <name> "<task>" --model M --reason "<why>" '
            '[--cwd DIR] [--trust] [--permission-mode MODE]\n  ' + spawn_mandate_error())
    name, task = argv[0], argv[1]
    rest, model, reason, cwd, trust = argv[2:], "", "", os.getcwd(), False
    permission_mode = ""
    while rest:
        if rest[0] == "--model" and len(rest) > 1:
            model, rest = rest[1], rest[2:]
        elif rest[0] == "--reason" and len(rest) > 1:
            reason, rest = rest[1], rest[2:]
        elif rest[0] == "--cwd" and len(rest) > 1:
            cwd, rest = rest[1], rest[2:]
        elif rest[0] == "--permission-mode" and len(rest) > 1:
            permission_mode, rest = rest[1], rest[2:]
        elif rest[0] == "--trust":
            # OPT-IN, default off. Pre-approves cwd's workspace-trust prompt
            # so a throwaway/experiment dir never wedges a session on it (the
            # bug this whole task started from). Scoped to the exact --cwd
            # given, one dir at a time — never a blanket "trust everything"
            # switch. NOT for normal agents in real repos: a real repo is
            # either already trusted (the human uses it directly) or SHOULD
            # keep the prompt (an unfamiliar dir is exactly what the gate
            # exists to catch). This flag exists for harnesses that spawn
            # into a fresh tempdir per run, where "trust" has no meaningful
            # content to withhold.
            trust, rest = True, rest[1:]
        else:
            die(f"spawn: unknown flag {rest[0]}")
    import re as _re
    if not _re.match(NAME_RE, name):
        die(f"bad name '{name}': lowercase letters, digits, hyphens (max 40). "
            f"The name is chosen, not derived — pick one that names the work.")
    if name in ("operator", "delivered"):
        die(f"'{name}' is reserved")
    if not task.strip():
        die("spawn needs a non-empty task")
    if os.environ.get("HERDR_ENV") != "1":
        die("not inside herdr (HERDR_ENV != 1); spawn needs herdr as the container")

    # THE MANDATE. Placement is load-bearing and was chosen, not defaulted: this guard sits
    # AFTER the bad-name / reserved-name / empty-task / not-in-herdr refusals and BEFORE the
    # tombstone is claimed. Both halves matter.
    #   - After, because those refusals must keep their OWN stderr. A guard hoisted to the top
    #     of the function (the naive spot, right after flag-parse) HIJACKS them: `spawn "bad
    #     name"` would answer "you forgot --reason" instead of "bad name", and the six
    #     name-refusal cases would all start failing for a reason that has nothing to do with
    #     names. Worse, a test asserting only `returncode == 1` STAYS GREEN while silently
    #     ceasing to test anything — the most dangerous outcome in this whole change.
    #   - Before, because a refused spawn must not burn the name. The tombstone is forever;
    #     a parent who forgot a flag has not spent their name on it.
    if not model or not reason.strip():
        die(spawn_mandate_error())
    if model.lower() in BANNED_MODELS:
        die(f"{model} is banned by standing operator policy — see bin/swarm's "
            f"BANNED_MODELS comment for why.")
    root = root_dir()
    conf = read_config(root)
    harness, launch_model = resolve_model_alias(model, conf)
    if harness is None:
        aliases = tuple(sorted((conf.get("models") or {}).keys()))
        known = SPAWN_MODELS + aliases
        die(f"unknown model '{model}' — tokens: {' '.join(known)}. "
            f"There is no default: every spawn names a real model. "
            f"See `swarm models` for what's spawnable.")
    if len(reason) > REASON_CAP:
        die(f"--reason is {len(reason)} chars; the cap is {REASON_CAP}. It is a clause, "
            f"not an essay — if it does not fit, the thinking is not done.")

    parent = my_name()

    # Resolve the permission mode BEFORE the name is claimed, same reasoning as
    # the mandate guard above: an invalid --permission-mode must refuse without
    # burning the child's name. Precedence: --permission-mode flag, else
    # .swarm/config's [spawn] permission_mode, else DEFAULT_PERMISSION_MODE
    # (auto) — never Claude Code's own built-in default (manual), which is the
    # wedge this whole change exists to fix.
    if not permission_mode:
        permission_mode = configured_permission_mode(root) or DEFAULT_PERMISSION_MODE
    if permission_mode not in PERMISSION_MODES:
        die(f"unknown --permission-mode '{permission_mode}' — accepted values: "
            f"{', '.join(PERMISSION_MODES)} (verbatim from `claude --help`).")

    # C3 dispatch (docs/design/PRODUCTIZE.md §3): the harness is NAMED by the
    # alias, never deduced from the model token's shape. Everything below is a
    # refusal that must fire BEFORE the name is claimed — same reasoning as the
    # mandate guard above.
    yoke_path = None
    if harness == "yoke":
        yoke_path = (conf.get("harness") or {}).get("yoke")
        if not yoke_path:
            die("alias resolves to harness 'yoke' but [harness].yoke is not "
                "configured in .swarm/config — add "
                '{"harness": {"yoke": "/path/to/yoke"}} (see `swarm models`).')
        auth_note = provider_auth_refusal(launch_model)
        if auth_note:
            die(auth_note)
        # C4: --permission-mode must be EXPRESSIBLE for yoke too, but manual/
        # dontAsk mean "ask a human" — refuse rather than silently wedge an
        # unattended agent (docs/design/PRODUCTIZE.md §4).
        if permission_mode in ("manual", "dontAsk"):
            die(f"--permission-mode {permission_mode} means \"ask a human\" — "
                f"a yoke agent is unattended and has no one to ask. Use auto "
                f"(default), plan, acceptEdits, or bypassPermissions.")
    elif harness != "claude":
        die(f"alias names harness '{harness}'; the harnesses are claude, yoke.")

    if harness == "yoke":
        # yoke claims its OWN tombstone (same claim_name contract, its own
        # copy) — bin/swarm must not claim it first, or the child's own claim
        # would collide with its parent's. bin/swarm stays alive (subprocess,
        # not exec) only to pass argv/exit code through and report failure.
        dispatch_yoke(name, task, launch_model, parent, reason, root,
                      yoke_path, conf, permission_mode)
        return

    # Claim the name FIRST: journal-as-tombstone. A name ever used errors here.
    try:
        fd = claim_name(root, name)
    except FileExistsError:
        die(f"name '{name}' was already used (journal/{name}.md exists); "
            f"a name is one agent, forever — pick another")
    with os.fdopen(fd, "w") as f:
        # The model AND the reason go in the child's FIRST journal entry, where they are
        # read by the two audiences that matter and by nobody who has to go looking:
        # the CHILD (which learns, in its own words, what it was picked for and what its
        # parent expects to be able to check) and any LATER READER of the journal — the
        # one artifact this whole society already agrees is the record. A reason filed
        # only into a JSON the tool reads back would be write-only; this is the surface
        # where a compelled sentence has ever actually changed behaviour here.
        f.write(f"# journal of {name}\n\n## {fmt_ts(now_ms())} — spawned\n"
                f"Model: {model} — {reason}\n"
                f"Task from {parent}: {task}\n")

    # Spawn plumbing: settings (hooks -> this file), task file, launcher.
    sdir = settings_dir(root)
    os.makedirs(sdir, exist_ok=True)
    self_path = shlex.quote(os.path.realpath(__file__))

    def h(cmd):
        return {"matcher": "", "hooks": [{"type": "command",
                                          "command": f"{self_path} {cmd}"}]}
    settings = os.path.join(sdir, f"{name}.json")
    write_atomic(settings, json.dumps({"hooks": {
        "UserPromptSubmit": [h("deliver")],
        "Stop": [h("event stop")],
        "Notification": [h("event notification")],
        "SessionStart": [h("restore")]}}))
    taskfile = os.path.join(sdir, f"{name}.task")
    write_atomic(taskfile, spawn_header(name, parent) + task)
    statusfile = os.path.join(sdir, f"{name}.status")
    try:
        os.unlink(statusfile)
    except OSError:
        pass
    launcher = os.path.join(sdir, f"{name}.launch.sh")
    write_launcher(launcher, statusfile, settings, taskfile, launch_model, permission_mode)

    if trust:
        pre_trust_dir(os.path.realpath(cwd))

    # One tab per agent: the pane is what makes the society observable.
    # Pin the child to the SPAWNER's workspace (HERDR_WORKSPACE_ID, set by
    # herdr in every pane): without --workspace, herdr places the tab in the
    # currently FOCUSED workspace, so a child could land in whatever space
    # the human happens to be viewing. Unset (shouldn't happen inside herdr,
    # but be safe) falls back to today's behavior rather than crashing.
    args = ["tab", "create", "--cwd", cwd, "--no-focus", "--label", name,
            "--env", f"SWARM_DIR={root}", "--env", f"SWARM_AGENT_ID={name}"]
    ws = os.environ.get("HERDR_WORKSPACE_ID")
    if ws:
        args[2:2] = ["--workspace", ws]
    d = herdr_json(args)
    pane = tab = ""
    try:
        pane = d["result"]["root_pane"]["pane_id"]
        tab = d["result"]["tab"]["tab_id"]
    except Exception:
        pass
    if not pane:
        die("herdr tab create failed")
    subprocess.run(["herdr", "pane", "run", pane, herdr_run_path(launcher)],
                   capture_output=True)

    # Record the binding BEFORE the readiness wait: the record + the launcher
    # signal are the truth; a slow start must never lose the agent.
    write_atomic(agent_rec_path(root, name), json.dumps(
        {"name": name, "parent": parent, "pane": pane, "tab": tab,
         "model": model, "reason": reason, "cwd": cwd, "task": task,
         "ts": now_ms()}))

    # Readiness = the launcher's own fired signal. Ambiguity is life: only a
    # CONFIRMED "failed" tears down; a silent timeout keeps the agent.
    timeout = int(os.environ.get("SWARM_READY_TIMEOUT", "30"))
    t0, outcome = time.time(), "unknown"
    while True:
        try:
            with open(statusfile) as f:
                s = f.read()
            if s.startswith("failed"):
                outcome = "failed"
                break
            if s.startswith("launching"):
                outcome = "started"
                break
        except OSError:
            pass
        if time.time() - t0 >= timeout:
            break
        time.sleep(1)
    if outcome == "failed":
        with open(statusfile) as f:
            reason = f.read().strip()
        if tab:
            subprocess.run(["herdr", "tab", "close", tab], capture_output=True)
        try:
            os.unlink(agent_rec_path(root, name))  # binding goes; tombstone stays
        except OSError:
            pass
        die(f"agent {name} did not start: {reason}")
    if outcome == "unknown":
        print(f"swarm: warning: {name} launch unconfirmed after {timeout}s; "
              f"keeping it — check its pane", file=sys.stderr)
    print(name)


def cmd_send(argv):
    to, body, from_stdin, have_pos = "", "", False, False
    rest = list(argv)
    while rest:
        a = rest.pop(0)
        if a == "--stdin":
            from_stdin = True
        elif a.startswith("-"):
            die(f"send: unknown flag {a}")
        elif not to:
            to = a
        else:
            body, have_pos = a, True
    if from_stdin:
        # Bytes off stdin, never a shell word: a positional body containing
        # backticks/$()/apostrophes is mangled by the CALLER's shell before we
        # can see it. Passing both is an error, not a precedence rule.
        if have_pos:
            die("send: --stdin takes the body from stdin; drop the positional message")
        if sys.stdin.isatty():
            die("send --stdin: no message on stdin (pipe or redirect one in)")
        body = sys.stdin.read()
    if not to or not body:
        die('send needs: swarm send <name> --stdin   (or: swarm send <name> "<msg>")')

    root = root_dir()
    agents = load_agents(root)
    if to != "operator" and to not in agents:
        die(f"unknown agent: {to}")
    sender = my_name()
    rec = {"to": to, "from": sender, "ts": now_ms(), "body": body}
    err = send_size_error(rec, relation(sender, to, parents_of(agents)))
    if err:
        die(err)
    # Send middleware — admission control (HOOK-WIRING §13): when a
    # middleware is configured in .swarm/config, EVERY send runs it here, in
    # the sender's process, BEFORE the queue write, with the full envelope
    # (from/to/ts/body) on stdin. The message does not exist in any queue
    # until the middleware passes it — admission is a code fact, not a
    # tendency. The tool carries NO policy about what the middleware does;
    # the verdict is its EXIT CODE alone (stdout is never parsed):
    #   - exit 0        -> PASS: queue_put below (next() — success = continue);
    #   - exit 100      -> HANDLED: deliberate don't-pass — the middleware
    #     owned the message (answered/dropped/forwarded via its own sends,
    #     in its own wire name); nothing queued here;
    #   - any other exit / timeout / killed / not configured -> FAIL-OPEN:
    #     queued unchanged — crash, set -e, command-not-found all pass
    #     through safely; a broken middleware degrades to no middleware
    #     IN CODE (100 is the only don't-queue value precisely so an
    #     incidental failure can never read as a deliberate drop).
    # If the SENDER's process dies while the middleware runs, this send
    # never returned and the message was never ACCEPTED — the sender
    # observes its own failed command and retries per its briefing
    # (producer-side-interceptor semantics; "nothing silently dropped"
    # governs accepted messages, and an unaccepted send has the sender as
    # its observer).
    proceed = True
    reg = registered_middleware(root)
    if reg and sender != reg[0]:  # recursion guard: its own sends bypass
        identity, command, timeout = reg
        # Inject the swarm env contract: a bare subprocess inherits the
        # SENDER's env, and anything the middleware sends would be attributed
        # to the original sender. The config identity IS what is injected.
        env = {**os.environ, "SWARM_AGENT_ID": identity, "SWARM_DIR": root}
        try:
            p = subprocess.run(shlex.split(command), input=json.dumps(rec),
                               text=True, env=env,
                               timeout=timeout, capture_output=True)
            proceed = p.returncode != MIDDLEWARE_HANDLED_EXIT
        except Exception:
            pass  # timeout/kill/crash: fail open, queue below
    if proceed:
        try:
            queue_put(root, rec)
        except OSError as e:
            die(f"could not queue message: {e}")

    # Doorbell, best-effort, only for mail that was actually queued. The
    # operator is a mailbox, not a node: no pane, no doorbell, no warning —
    # the human sees the mail at the top of `ps`.
    if proceed and to != "operator":
        pane = agents[to].get("pane", "")
        if not (pane and ring_doorbell(pane)):
            print(f"swarm: note: doorbell to {to} skipped (pane unavailable); "
                  f"message is durably queued — if {to} is closed (see the "
                  f"dead: line in swarm ps) it will never be delivered; look "
                  f"for a successor in its journal or its parent's",
                  file=sys.stderr)


def cmd_ps(argv):
    # `--reason` is OPT-IN, and it prints BELOW the tree — never inside it. Three reasons,
    # and the third is the one that actually decides it:
    #   1. The tree is a SCANNABLE view. Its whole job is that you can find one agent's row
    #      at a glance. A sentence per row destroys exactly that, and it destroys it worst
    #      when the tree is big — i.e. precisely when you need it.
    #   2. The reason is written for the CHILD and for the LATER READER, and both already
    #      have it: it is in the child's own first journal entry (see cmd_spawn). `ps` is
    #      not where that audience reads.
    #   3. It is ATTACKER-CONTROLLED FREE TEXT, and this view has been burned on that twice
    #      already — see model_of() in render_ps, which had to move the pin into a slot of
    #      its own because `--model you` forged the `(you)` marker. A model id is one short
    #      token and STILL needed a sanitizer and a cap. A --reason is unbounded prose that
    #      any agent can write. Putting it in the default tree would hand every agent a
    #      several-hundred-character, newline-capable pen aimed at the one view the operator
    #      trusts to tell them what is true. So: not in the tree, and sanitized even here.
    show_reason = False
    if argv == ["--reason"]:
        show_reason = True
    elif argv:
        die("ps takes no arguments, or --reason (the model choice for each agent)")
    root = root_dir()
    agents = load_agents(root)
    live = live_pane_set()
    queues = {n: len(list_waiting(root, n)) for n in agents}
    junk = {n: count_junk(root, n) for n in agents}
    events = {n: read_json(event_path(root, n)) for n in agents}
    op_mail = [(r.get("from", "?"), int(r.get("ts") or 0))
               for _, _, r in list_waiting(root, "operator")]
    now = now_ms()
    # Live reads: bounded to candidates only (blocked_candidates), never the
    # whole fleet — see read_blocked. herdr unreachable (live is None) means
    # nothing to read; an empty dict is correct, not a degraded one.
    blocked = read_blocked(root, agents, live, events, now) if live is not None else {}
    out = render_ps(agents, live, queues, events, my_name(), op_mail, now,
                    junk, blocked)
    if live is None and agents:
        out += "\n(herdr unreachable — liveness unknown)"
    if show_reason:
        out += "\n\nmodel choices — why each parent picked what it picked:"
        rows = []
        for n in sorted(agents):
            m = str(agents[n].get("model") or "")
            r = str(agents[n].get("reason") or "")
            # Same sanitizer discipline as model_of(), same reason, and deliberately not one
            # notch weaker: the RECORD keeps the text verbatim (it is the truth), and the
            # VIEW protects itself. A reason is free text ANY agent can write — attacker-
            # controlled, and longer and freer than the pin ever was — so it gets the pin's
            # exclude-list treatment:
            #   - collapse whitespace: a newline would forge a row of THIS VERY LIST. This
            #     is the sharp edge, and it is why the list is flat and not a tree.
            #   - drop non-printables: this strips the ESC out of an ANSI escape. What is
            #     left ("[31m") is inert text, not a control sequence — the ESC is what
            #     made it an escape, and the ESC is gone.
            #   - drop MODEL_STRUCTURAL: the box glyphs that draw the tree and the parens
            #     that delimit `(you)`. A reason cannot forge a tree row from down here,
            #     but it must not be able to DRAW tree-looking structure either — the one
            #     view the operator trusts must never render an agent's own prose as
            #     structure. model_of() excludes exactly this set; so does this.
            #   - cap with an ellipsis: a cut clause must be VISIBLY a fragment.
            r = "".join(c for c in r
                        if c.isprintable() and c not in MODEL_STRUCTURAL)
            r = " ".join(r.split())
            if len(r) > REASON_CAP:
                r = r[:REASON_CAP - 1] + "…"
            if not m and not r:
                # A pre-mandate agent: spawned before --model/--reason existed. Say so
                # plainly. The absence IS the finding this change was built to end — do
                # not paper over it with a blank.
                rows.append(f"  {n}: (spawned before the mandate — no choice recorded)")
            else:
                rows.append(f"  {n}: {m or '?'} — {r or '(no reason recorded)'}")
        out += "\n" + ("\n".join(rows) if rows else "  (no agents)")
    print(out)


def cmd_close(argv):
    if len(argv) != 1:
        die("close needs exactly one name: swarm close <name>")
    root = root_dir()
    agents = load_agents(root)
    name = argv[0]
    if name not in agents:
        die(f"unknown agent: {name}")
    for aid in subtree(agents, name):
        a = agents[aid]
        gone, already, timed_out, kind = False, False, False, None
        if a.get("tab"):
            kind, ids = "tab", listed_ids("tab")
            if ids is not None and a["tab"] not in ids:
                already = True
            else:
                subprocess.run(["herdr", "tab", "close", a["tab"]],
                               capture_output=True)
                gone = wait_gone("tab", a["tab"])
                timed_out = not gone
        elif a.get("pane"):
            kind, ids = "pane", listed_ids("pane")
            if ids is not None and a["pane"] not in ids:
                already = True
            else:
                subprocess.run(["herdr", "pane", "close", a["pane"]],
                               capture_output=True)
                gone = wait_gone("pane", a["pane"])
                timed_out = not gone
        if gone or already:
            print(f"closed {aid}" if gone else f"{aid}: pane already gone")
        elif timed_out:
            print(f"{aid}: close requested, {kind} still present after 3s "
                  f"(may be tearing down)")
        else:
            print(f"{aid}: pane already gone")
    print(f"files stay under {root} (journal, queue, delivered)")


def cmd_models():
    """Read-only discovery: what --model tokens are spawnable. Writes nothing —
    no file, no state change. Lists the four builtin Claude tokens (ready iff
    `claude` is on PATH) and every config [models] alias, each shown with its
    NAMED harness and resolved model (docs/design/PRODUCTIZE.md §3 — the
    harness is declared in the alias, never deduced). PR 1 only DEFINES and
    DISPLAYS this schema; dispatching a yoke alias to a real harness is PR 3."""
    root = root_dir()
    conf = read_config(root)   # read_config itself prints the legacy-TOML warning

    claude_ready = shutil.which("claude") is not None
    rows = []  # (token, harness, resolved model, ready/note)
    for tok in SPAWN_MODELS:
        rows.append((tok, "claude", tok, "ready" if claude_ready else "claude not on PATH"))

    aliases = conf.get("models") or {}
    for name in sorted(aliases):
        entry = aliases[name] or {}
        harness = str(entry.get("harness") or "?")
        model = str(entry.get("model") or "?")
        if harness == "claude":
            ready = "ready" if claude_ready else "claude not on PATH"
        elif harness == "yoke":
            ready = "ready" if shutil.which("yoke") is not None else "yoke not on PATH"
        else:
            ready = f"unknown harness '{harness}'"
        rows.append((name, harness, model, ready))

    w_tok = max(len(r[0]) for r in rows)
    w_harness = max(len(r[1]) for r in rows)
    w_model = max(len(r[2]) for r in rows)
    print(f"{'TOKEN'.ljust(w_tok)}  {'HARNESS'.ljust(w_harness)}  "
          f"{'MODEL'.ljust(w_model)}  READY")
    for tok, harness, model, ready in rows:
        print(f"{tok.ljust(w_tok)}  {harness.ljust(w_harness)}  "
              f"{model.ljust(w_model)}  {ready}")


def cmd_world():
    # WORLD.md sits at the repo root, one level above bin/ (realpath first:
    # the installed `swarm` is a symlink into the checkout)
    doc = os.path.join(
        os.path.dirname(os.path.dirname(os.path.realpath(__file__))), "WORLD.md")
    try:
        with open(doc) as f:
            sys.stdout.write(f.read())
    except OSError:
        die(f"WORLD.md not found at the repo root (expected {doc})")


USAGE = """swarm (simplest) — four verbs. An agent is a session in a pane with a
name, a parent, and a journal. A message is a claim on one turn.

  swarm spawn <name> "<task>" --model M --reason "<why>" [--cwd DIR] [--trust]
                              [--permission-mode MODE]
                                create a child; the name is chosen, not derived;
                                a name ever used errors.
                                --model and --reason are BOTH REQUIRED: the
                                parent chooses the child's model. The reason
                                answers ONE question — can you cheaply tell that
                                this child was wrong? Cheap to check (you re-read
                                the diff anyway) → a small model's error is free;
                                expensive to check (you'd redo the reasoning) →
                                pay for the strong one. Say THAT, not why the
                                model is good. Tokens: opus sonnet fable haiku,
                                plus any config [models] alias (see `swarm
                                models`). There is no default — silence is
                                never free.
                                --trust pre-approves --cwd's workspace-trust
                                prompt (opt-in, default off — for throwaway dirs
                                only, never for real repos)
                                --permission-mode MODE sets the child's Claude
                                Code permission mode (default: auto — can edit
                                files and reach the network unattended, cannot
                                bypass the out-of-cwd write sandbox). Accepted:
                                acceptEdits auto bypassPermissions manual
                                dontAsk plan (verbatim from `claude --help`).
                                Overridable per-spawn here, or as a standing
                                default via .swarm/config's [spawn]
                                permission_mode.
  swarm send <name> --stdin     message an agent or `operator` (body from stdin —
  swarm send <name> "<msg>"     recommended; a positional body is a shell word).
                                Delivered whole, ONE per turn, oldest first. Must
                                fit one turn's injection (8000 chars) or send
                                refuses: put it in a file, send the path.
  swarm ps                      the one view: tree, liveness, queue depth,
                                idle-since, last words; operator mail on top
  swarm ps --reason             the same tree, plus each agent's model and the
                                reason its parent gave — printed BELOW the tree,
                                never inside it (a sentence per row would wreck
                                the one view you scan)
  swarm close <name>            end an agent and its subtree; files stay
  swarm world                   print the contract (two screens)
  swarm models                  read-only: list spawnable models — the four
                                builtin Claude tokens, and any config [models]
                                aliases with their named harness and resolved
                                model. Writes nothing.

State: ./.swarm (override with SWARM_DIR). Journals at .swarm/journal/<name>.md —
world-readable; read your children's. deliver/event/restore are hook entrypoints
(wired automatically at spawn), not for humans. A send middleware, if configured
in .swarm/config ([middleware] section), is run by send itself before queuing."""


def main(argv):
    if not argv or argv[0] in ("-h", "--help", "help"):
        print(USAGE)
        sys.exit(0 if argv else 1)
    verb, rest = argv[0], argv[1:]
    if verb == "spawn":
        cmd_spawn(rest)
    elif verb == "send":
        cmd_send(rest)
    elif verb == "ps":
        cmd_ps(rest)
    elif verb == "close":
        cmd_close(rest)
    elif verb == "world":
        cmd_world()
    elif verb == "models":
        cmd_models()
    elif verb == "deliver":
        cmd_deliver()
    elif verb == "event":
        cmd_event(rest[0] if rest else "")
    elif verb == "restore":
        cmd_restore()
    else:
        print(USAGE, file=sys.stderr)
        die(f"unknown verb: {verb}")


if __name__ == "__main__":
    main(sys.argv[1:])
